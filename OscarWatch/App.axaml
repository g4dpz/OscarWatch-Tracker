<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OscarWatch.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <Style Selector="Window">
            <Setter Property="Icon" Value="/icons/OscarWatch-Icon.png" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        </Style>
        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.dialog-footer">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        </Style>
        <Style Selector="Expander">
            <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <!-- Overridden per theme in AccessibilityThemeResources -->
        <SolidColorBrush x:Key="ThemeForegroundBrush" Color="#1A1A1A" />
        <SolidColorBrush x:Key="ThemeSecondaryForegroundBrush" Color="#525252" />
        <SolidColorBrush x:Key="ThemePlaceholderForegroundBrush" Color="#5C6370" />
        <x:Double x:Key="TextControlPlaceholderOpacity">1</x:Double>
        <SolidColorBrush x:Key="PassHighlightBrush" Color="#2B6E1F" />
        <SolidColorBrush x:Key="PassInProgressBackgroundBrush" Color="#D4EDCC" />
        <SolidColorBrush x:Key="PassRecordingBackgroundBrush" Color="#C8E6C0" />
        <SolidColorBrush x:Key="PassImminentBackgroundBrush" Color="#FFF0D4" />
        <SolidColorBrush x:Key="PassImminentBadgeBackgroundBrush" Color="#E89B1E" />
        <SolidColorBrush x:Key="PassImminentBadgeForegroundBrush" Color="#1A1A1A" />
        <SolidColorBrush x:Key="PassInProgressBadgeBackgroundBrush" Color="#2B6E1F" />
        <SolidColorBrush x:Key="PassInProgressBadgeForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="HamsAtGridBadgeBackgroundBrush" Color="#2B6E1F" />
        <SolidColorBrush x:Key="PassRecordingBadgeBackgroundBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="PassRecordingBadgeForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="StaleTleForegroundBrush" Color="#B45309" />
        <SolidColorBrush x:Key="SunlightStatusBrush" Color="#B8860B" />
        <SolidColorBrush x:Key="EclipseStatusBrush" Color="#5C6370" />
    </Application.Resources>
</Application>