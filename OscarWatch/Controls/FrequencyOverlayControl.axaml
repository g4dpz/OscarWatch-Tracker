<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OscarWatch.ViewModels"
             xmlns:models="using:OscarWatch.Core.Models"
             xmlns:loc="using:OscarWatch.Localization"
             x:Class="OscarWatch.Controls.FrequencyOverlayControl"
             x:DataType="vm:FrequencyOverlayViewModel"
             MinWidth="{Binding OverlayMinWidth}"
             MaxWidth="{Binding OverlayMaxWidth}">
  <UserControl.Styles>
    <Style Selector="TextBlock.freq-mono">
      <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
      <Setter Property="TextAlignment" Value="Right" />
    </Style>
    <Style Selector="NumericUpDown.offset-spin">
      <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="140" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="Padding" Value="8,0,0,0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="NumericUpDown.offset-spin /template/ TextBox#PART_TextBox">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="10,0,4,0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="LineHeight" Value="22" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="NumericUpDown.offset-spin /template/ TextBox#PART_TextBox /template/ ScrollViewer#PART_ScrollViewer">
      <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
      <Setter Property="HorizontalScrollBarVisibility" Value="Hidden" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="NumericUpDown.offset-spin /template/ TextBox#PART_TextBox /template/ TextPresenter#PART_TextPresenter">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="LineHeight" Value="22" />
      <Setter Property="Margin" Value="0,2,0,0" />
    </Style>
    <Style Selector="NumericUpDown.offset-spin /template/ ButtonSpinner">
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="Height" Value="36" />
    </Style>
    <Style Selector="Button.offset-step">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#FF1E1E1E" />
      <Setter Property="BorderBrush" Value="#FF505050" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>
    <Style Selector="Button.offset-step /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.offset-step:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FF2A2A2A" />
      <Setter Property="BorderBrush" Value="#FF606060" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>
    <Style Selector="Button.offset-step:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FF181818" />
      <Setter Property="BorderBrush" Value="#FF505050" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>
    <Style Selector="Button.store-offset">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#FF2A3A2A" />
      <Setter Property="BorderBrush" Value="#FF507050" />
      <Setter Property="Foreground" Value="#FFE0FFE0" />
    </Style>
    <Style Selector="Button.store-offset /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.store-offset:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FF354535" />
      <Setter Property="BorderBrush" Value="#FF609060" />
      <Setter Property="Foreground" Value="#FFE0FFE0" />
    </Style>
    <Style Selector="Button.operating-style-active /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FF2A3A2A" />
      <Setter Property="BorderBrush" Value="#FF507050" />
      <Setter Property="Foreground" Value="#FFE0FFE0" />
    </Style>
    <Style Selector="Button.doppler-strategy-header">
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="MaxHeight" Value="26" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#FF1E1E1E" />
      <Setter Property="BorderBrush" Value="#FF505050" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>
    <Style Selector="Button.doppler-strategy-header /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="TextBlock.TextAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.doppler-strategy-header:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FF2A2A2A" />
      <Setter Property="BorderBrush" Value="#FF606060" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>
    <Style Selector="Button.operating-style-header">
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="MaxHeight" Value="26" />
      <Setter Property="MinWidth" Value="52" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="#FF1E1E1E" />
      <Setter Property="BorderBrush" Value="#FF505050" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>
    <Style Selector="Button.operating-style-header /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.operating-style-header:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FF2A2A2A" />
      <Setter Property="BorderBrush" Value="#FF606060" />
      <Setter Property="Foreground" Value="#FFFFFFFF" />
    </Style>
    <Style Selector="Button.store-offset:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FF243024" />
      <Setter Property="BorderBrush" Value="#FF507050" />
      <Setter Property="Foreground" Value="#FFE0FFE0" />
    </Style>
    <Style Selector="Button.store-offset:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FF2A3A2A" />
      <Setter Property="BorderBrush" Value="#FF404040" />
      <Setter Property="Foreground" Value="#FF808080" />
    </Style>
    <Style Selector="Ellipse.doppler-lead-dot">
      <Setter Property="Width" Value="7" />
      <Setter Property="Height" Value="7" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Ellipse.doppler-lead-dot.idle">
      <Setter Property="Fill" Value="#FF5A5A5A" />
    </Style>
    <Style Selector="Ellipse.doppler-lead-dot.active">
      <Setter Property="Fill" Value="#FFFFB020" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg">
      <Setter Property="Foreground" Value="{DynamicResource ToggleSwitchContentForeground}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Width" Value="40" />
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="MaxWidth" Value="40" />
      <Setter Property="KnobTransitions">
        <Transitions>
          <DoubleTransition Property="Canvas.Left" Duration="0:0:0.2" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
      <Setter Property="Template">
        <ControlTemplate TargetType="ToggleSwitch">
          <!-- Compact switch only — default Fluent template reserves 12px + label slot beside the track. -->
          <Grid Width="40"
                Height="20"
                VerticalAlignment="Center"
                TemplatedControl.IsTemplateFocusTarget="True"
                Background="Transparent">
            <Border x:Name="OuterBorder"
                    Width="40"
                    Height="20"
                    CornerRadius="10"
                    Background="{DynamicResource ToggleSwitchFillOff}"
                    BorderBrush="{DynamicResource ToggleSwitchStrokeOff}"
                    BorderThickness="{DynamicResource ToggleSwitchOuterBorderStrokeThickness}" />
            <Border x:Name="SwitchKnobBounds"
                    Width="40"
                    Height="20"
                    CornerRadius="10"
                    Background="{DynamicResource ToggleSwitchFillOn}"
                    BorderBrush="{DynamicResource ToggleSwitchStrokeOn}"
                    BorderThickness="{DynamicResource ToggleSwitchOnStrokeThickness}"
                    Opacity="0" />
            <Canvas x:Name="PART_SwitchKnob" Width="20" Height="20" HorizontalAlignment="Left">
              <Grid x:Name="PART_MovingKnobs" Width="20" Height="20">
                <Ellipse x:Name="SwitchKnobOn"
                         Width="10"
                         Height="10"
                         Opacity="0"
                         Fill="{DynamicResource ToggleSwitchKnobFillOn}" />
                <Ellipse x:Name="SwitchKnobOff"
                         Width="10"
                         Height="10"
                         Fill="{DynamicResource ToggleSwitchKnobFillOff}" />
              </Grid>
            </Canvas>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:checked /template/ Border#OuterBorder">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:checked /template/ Border#SwitchKnobBounds">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:checked /template/ Ellipse#SwitchKnobOff">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:checked /template/ Ellipse#SwitchKnobOn">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:unchecked /template/ Border#OuterBorder">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:unchecked /template/ Border#SwitchKnobBounds">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:unchecked /template/ Ellipse#SwitchKnobOff">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:unchecked /template/ Ellipse#SwitchKnobOn">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:pointerover /template/ Border#OuterBorder">
      <Setter Property="BorderBrush" Value="{DynamicResource ToggleSwitchStrokeOffPointerOver}" />
      <Setter Property="Background" Value="{DynamicResource ToggleSwitchFillOffPointerOver}" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:pointerover /template/ Border#SwitchKnobBounds">
      <Setter Property="Background" Value="{DynamicResource ToggleSwitchFillOnPointerOver}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ToggleSwitchStrokeOnPointerOver}" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:pointerover /template/ Ellipse#SwitchKnobOff">
      <Setter Property="Fill" Value="{DynamicResource ToggleSwitchKnobFillOffPointerOver}" />
    </Style>
    <Style Selector="ToggleSwitch.offset-leg:pointerover /template/ Ellipse#SwitchKnobOn">
      <Setter Property="Fill" Value="{DynamicResource ToggleSwitchKnobFillOnPointerOver}" />
    </Style>
    <Style Selector="TextBlock.offset-leg-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#FFE0E0E0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <Border Background="#FF121212"
          BorderBrush="#FF505050"
          BorderThickness="1"
          CornerRadius="8"
          Padding="0"
          BoxShadow="0 6 20 0 #AA000000">
    <StackPanel Spacing="0">
      <Border x:Name="DragHandle"
              Background="#FF1E1E1E"
              BorderBrush="#FF404040"
              BorderThickness="0,0,0,1"
              Cursor="SizeAll"
              Padding="8,6"
              CornerRadius="8,8,0,0">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
              ColumnSpacing="8"
              VerticalAlignment="Center">
          <TextBlock x:Name="CollapseToggle"
                     Grid.Column="0"
                     Text="{Binding CollapseToggleGlyph}"
                     ToolTip.Tip="{Binding CollapseToggleToolTip}"
                     FontSize="12"
                     LineHeight="16"
                     Foreground="#FFB0B0B0"
                     VerticalAlignment="Center"
                     Margin="0,0,2,0"
                     Cursor="Hand"
                     Tapped="OnCollapseToggleTapped" />
          <TextBlock Grid.Column="1"
                     Text="{Binding SatelliteName}"
                     IsVisible="{Binding !IsCollapsed}"
                     FontWeight="Bold"
                     FontSize="16"
                     Foreground="#FFFFFFFF"
                     VerticalAlignment="Center"
                     MaxWidth="120"
                     TextTrimming="CharacterEllipsis" />
          <StackPanel Grid.Column="1"
                      Grid.ColumnSpan="2"
                      Orientation="Horizontal"
                      Spacing="6"
                      IsVisible="{Binding IsCollapsed}"
                      VerticalAlignment="Center">
            <Ellipse Classes="doppler-lead-dot"
                     Classes.active="{Binding IsDopplerLeadActive}"
                     Classes.idle="{Binding !IsDopplerLeadActive}"
                     IsVisible="{Binding ShowDopplerLeadIndicator}"
                     ToolTip.Tip="{Binding DopplerLeadToolTip}" />
            <TextBlock Text="{Binding CollapsedSummaryText}"
                       FontFamily="Consolas,Courier New,monospace"
                       FontSize="12"
                       LineHeight="16"
                       Foreground="#FFE0E0E0"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <UniformGrid x:Name="OperatingStyleHeader"
                       Grid.Column="2"
                       Columns="2"
                       Rows="1"
                       Width="108"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="{Binding ShowHeaderOperatingStyle}">
            <Button Classes="operating-style-header"
                    Classes.operating-style-active="{Binding IsVoiceOperatingStyleSelected}"
                    Content="{loc:Localize Key=Freq.Voice}"
                    ToolTip.Tip="{Binding OperatingStyleHint}"
                    Command="{Binding SelectVoiceOperatingStyleCommand}"
                    Margin="0,0,3,0" />
            <Button Classes="operating-style-header"
                    Classes.operating-style-active="{Binding IsCwOperatingStyleSelected}"
                    Content="CW"
                    ToolTip.Tip="{Binding OperatingStyleHint}"
                    Command="{Binding SelectCwOperatingStyleCommand}"
                    Margin="3,0,0,0" />
          </UniformGrid>
          <TextBlock Grid.Column="3"
                     Text="⠿"
                     FontSize="14"
                     Foreground="#FF909090"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <StackPanel x:Name="ExpandedBody"
                  Spacing="12"
                  Margin="14,12,14,14"
                  IsVisible="{Binding !IsCollapsed}">
        <TextBlock Text="{Binding EmptyStateMessage}"
                   IsVisible="{Binding !HasTransponderData}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Foreground="#FFE0E0E0" />

        <StackPanel IsVisible="{Binding HasTransponderData}" Spacing="6">
          <TextBlock Text="{loc:Localize Key=Freq.TransponderMode}"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#FFE0E0E0" />

          <ComboBox ItemsSource="{Binding AvailableModes}"
                    SelectedItem="{Binding SelectedMode, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"
                    MinHeight="36"
                    FontSize="13"
                    Background="#FF1E1E1E"
                    BorderBrush="#FF505050"
                    Foreground="#FFFFFFFF">
            <ComboBox.SelectionBoxItemTemplate>
              <DataTemplate x:DataType="models:SatelliteTransponderMode">
                <TextBlock Text="{Binding DisplayLabel}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center" />
              </DataTemplate>
            </ComboBox.SelectionBoxItemTemplate>
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="models:SatelliteTransponderMode">
                <StackPanel Spacing="2" Margin="4,6">
                  <TextBlock Text="{Binding DisplayLabel}"
                             FontWeight="SemiBold"
                             FontSize="13"
                             Foreground="#FFFFFFFF" />
                  <TextBlock Text="{Binding SummaryLine}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             Foreground="#FFB0B0B0" />
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <Grid IsVisible="{Binding HasTransponderData}"
              ColumnDefinitions="52,*,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              ColumnSpacing="14"
              RowSpacing="8">
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{loc:Localize Key=Freq.UplinkTx}" FontSize="12" FontWeight="SemiBold"
                     Foreground="#FFB0B0B0" HorizontalAlignment="Right" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="{loc:Localize Key=Freq.DownlinkRx}" FontSize="12" FontWeight="SemiBold"
                     Foreground="#FFB0B0B0" HorizontalAlignment="Right" />

          <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Localize Key=Freq.Sat}" FontSize="14" FontWeight="SemiBold"
                     Foreground="#FFE0E0E0" VerticalAlignment="Center" />
          <TextBlock Grid.Row="1" Grid.Column="1" Classes="freq-mono"
                     Text="{Binding SatelliteTransmitText}"
                     IsVisible="{Binding !IsBeaconOnly}"
                     FontSize="18" FontWeight="SemiBold"
                     Foreground="#FFFFFFFF" />
          <TextBlock Grid.Row="1" Grid.Column="2" Classes="freq-mono"
                     Text="{Binding SatelliteReceiveText}"
                     FontSize="18" FontWeight="SemiBold"
                     Foreground="#FFFFFFFF" />

          <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Localize Key=Freq.Radio}" FontSize="14"
                     Foreground="#FFE0E0E0" VerticalAlignment="Center" />
          <TextBlock Grid.Row="2" Grid.Column="1" Classes="freq-mono"
                     Text="{Binding RadioTransmitText}"
                     IsVisible="{Binding !IsBeaconOnly}"
                     FontSize="18" FontWeight="SemiBold"
                     Foreground="#FF909090" />
          <TextBlock Grid.Row="2" Grid.Column="2" Classes="freq-mono"
                     Text="{Binding RadioReceiveText}"
                     FontSize="18" FontWeight="SemiBold"
                     Foreground="#FF909090" />

          <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                ColumnDefinitions="Auto,*"
                VerticalAlignment="Center">
            <Grid x:Name="DopplerStrategyRow"
                  Grid.Column="0"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="6"
                  IsVisible="{Binding ShowDopplerStrategyRow}"
                  HorizontalAlignment="Left"
                  Width="156">
              <Button Grid.Column="0"
                      Classes="doppler-strategy-header"
                      Classes.operating-style-active="{Binding IsFullDopplerSelected}"
                      Content="{loc:Localize Key=Freq.DopplerFull}"
                      ToolTip.Tip="{Binding DopplerStrategyHint}"
                      Command="{Binding SelectFullDopplerCommand}" />
              <Button Grid.Column="1"
                      Classes="doppler-strategy-header"
                      Classes.operating-style-active="{Binding IsTxFixedDopplerSelected}"
                      Content="{loc:Localize Key=Freq.DopplerTx}"
                      ToolTip.Tip="{loc:Localize Key=Freq.DopplerTxFixedToolTip}"
                      Command="{Binding SelectTxFixedDopplerCommand}" />
              <Button Grid.Column="2"
                      Classes="doppler-strategy-header"
                      Classes.operating-style-active="{Binding IsRxFixedDopplerSelected}"
                      Content="{loc:Localize Key=Freq.DopplerRx}"
                      ToolTip.Tip="{loc:Localize Key=Freq.DopplerRxFixedToolTip}"
                      Command="{Binding SelectRxFixedDopplerCommand}" />
            </Grid>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <Ellipse Classes="doppler-lead-dot"
                       Classes.active="{Binding IsDopplerLeadActive}"
                       Classes.idle="{Binding !IsDopplerLeadActive}"
                       IsVisible="{Binding ShowDopplerLeadIndicator}"
                       ToolTip.Tip="{Binding DopplerLeadToolTip}" />
              <TextBlock Classes="freq-mono"
                         Text="{Binding DopplerShiftText}"
                         FontSize="13"
                         Foreground="#FFB0B0B0"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Grid>

          <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                  IsVisible="{Binding ShowLeadTuningPanelVisible}"
                  Background="#FF252525"
                  BorderBrush="#FF505050"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="8,6">
            <StackPanel Spacing="6">
              <TextBlock Text="{loc:Localize Key=Freq.LeadTuningTitle}"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#FFE0E0E0" />
              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="10">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="{loc:Localize Key=Settings.Radio.DopplerCatLeadGain}"
                             FontSize="11"
                             Foreground="#FFB0B0B0" />
                  <NumericUpDown Value="{Binding LiveLeadGainPercent, Mode=TwoWay}"
                                 Minimum="10" Maximum="100"
                                 Increment="5" FormatString="F0"
                                 MinHeight="32"
                                 FontSize="13"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Text="{loc:Localize Key=Settings.Radio.DopplerCatLeadMs}"
                             FontSize="11"
                             Foreground="#FFB0B0B0" />
                  <NumericUpDown Value="{Binding LiveLeadMs, Mode=TwoWay}"
                                 Minimum="0" Maximum="100"
                                 Increment="5" FormatString="F0"
                                 MinHeight="32"
                                 FontSize="13"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Center" />
                </StackPanel>
              </Grid>
              <TextBlock Text="{loc:Localize Key=Freq.LeadTuningHint}"
                         FontSize="10"
                         TextWrapping="Wrap"
                         Foreground="#FF909090" />
            </StackPanel>
          </Border>

          <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Localize Key=Freq.Ctcss}" FontSize="14"
                     IsVisible="{Binding ShowCtcssRow}"
                     Foreground="#FFE0E0E0" VerticalAlignment="Center" />

          <ComboBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                    ItemsSource="{Binding CtcssToneOptions}"
                    SelectedItem="{Binding SelectedCtcssTone, Mode=TwoWay}"
                    IsVisible="{Binding ShowCtcssSelector}"
                    HorizontalAlignment="Stretch"
                    MinHeight="36"
                    FontSize="13"
                    Background="#FF1E1E1E"
                    BorderBrush="#FF505050"
                    Foreground="#FFFFFFFF">
            <ComboBox.SelectionBoxItemTemplate>
              <DataTemplate x:DataType="models:CtcssToneOption">
                <TextBlock Text="{Binding DisplayText}"
                           FontFamily="Consolas,Courier New,monospace"
                           FontSize="13"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center" />
              </DataTemplate>
            </ComboBox.SelectionBoxItemTemplate>
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="models:CtcssToneOption">
                <TextBlock Text="{Binding DisplayText}"
                           FontFamily="Consolas,Courier New,monospace"
                           FontSize="13"
                           Foreground="#FFFFFFFF"
                           VerticalAlignment="Center" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                     Text="{Binding SelectedCtcssText}"
                     IsVisible="{Binding ShowCtcssStatic}"
                     FontFamily="Consolas,Courier New,monospace"
                     FontSize="16" FontWeight="SemiBold"
                     Foreground="#FFFFFFFF"
                     VerticalAlignment="Center" />

          <TextBlock Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"
                     Text="{Binding CtcssHintText}"
                     IsVisible="{Binding ShowCtcssHint}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Foreground="#FFB0B0B0" />
        </Grid>

        <StackPanel IsVisible="{Binding HasTransponderData}" Spacing="10">
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding OffsetLabelText}" FontSize="12" FontWeight="SemiBold"
                       Foreground="#FFE0E0E0" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <NumericUpDown x:Name="OffsetUpDown"
                             Grid.Column="0"
                             Classes="offset-spin"
                             Value="{Binding ActiveOffsetKHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Minimum="-5" Maximum="5"
                             Increment="0.025" FormatString="F3"
                             MaxWidth="220"
                             HorizontalAlignment="Stretch"
                             VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center"
                             ValueChanged="OnOffsetSpinValueChanged" />
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Center"
                          IsVisible="{Binding ShowOffsetLegToggle}">
                <TextBlock Classes="offset-leg-label"
                           Text="{loc:Localize Key=Freq.OffsetToggleRx}" />
                <ToggleSwitch Classes="offset-leg"
                              IsChecked="{Binding IsTransmitOffsetSelected, Mode=TwoWay}"
                              OnContent=""
                              OffContent=""
                              ToolTip.Tip="{loc:Localize Key=Freq.OffsetLegToggleToolTip}" />
                <TextBlock Classes="offset-leg-label"
                           Text="{loc:Localize Key=Freq.OffsetToggleTx}" />
              </StackPanel>
            </Grid>
            <UniformGrid Columns="6" Rows="1">
              <Button Classes="offset-step" Content="+1000" Tag="1000" Click="OnOffsetStepClick" />
              <Button Classes="offset-step" Content="+100" Tag="100" Click="OnOffsetStepClick" />
              <Button Classes="offset-step" Content="+10" Tag="10" Click="OnOffsetStepClick" />
              <Button Classes="offset-step" Content="-10" Tag="-10" Click="OnOffsetStepClick" />
              <Button Classes="offset-step" Content="-100" Tag="-100" Click="OnOffsetStepClick" />
              <Button Classes="offset-step" Content="-1000" Tag="-1000" Click="OnOffsetStepClick" />
            </UniformGrid>
            <Button Classes="store-offset"
                    Content="{loc:Localize Key=Freq.StoreOffset}"
                    Command="{Binding StoreOffsetCommand}" />
          </StackPanel>
          <TextBlock Text="{Binding OffsetAppliedHint}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Foreground="#FF90C090" />
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
