<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        xmlns:models="using:OscarWatch.Core.Models"
        xmlns:services="using:OscarWatch.Core.Services"
        x:Class="OscarWatch.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="640" Height="520"
        MinWidth="560" MinHeight="360"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="0">
    <Border DockPanel.Dock="Bottom"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Cancel" Click="OnCancelClick" MinWidth="80" />
        <Button Content="Save" Click="OnSaveClick" Classes="accent" MinWidth="80" IsDefault="True" />
      </StackPanel>
    </Border>

    <TabControl Margin="12,12,12,8">
      <TabControl.Styles>
        <Style Selector="TabItem">
          <Setter Property="FontSize" Value="14" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Padding" Value="10,7" />
        </Style>
        <Style Selector="TabItem TextBlock">
          <Setter Property="FontSize" Value="14" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TabItem ScrollViewer StackPanel > TextBlock">
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style Selector="TabItem ScrollViewer > TextBlock">
          <Setter Property="FontSize" Value="11" />
          <Setter Property="FontWeight" Value="Normal" />
        </Style>
      </TabControl.Styles>
      <TabItem Header="Station">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,4">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="Display name" />
            <TextBox Text="{Binding DisplayName, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Latitude (°)" />
                <NumericUpDown Value="{Binding LatitudeDeg, Mode=TwoWay}"
                               Minimum="-90" Maximum="90" FormatString="F4" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Longitude (°)" />
                <NumericUpDown Value="{Binding LongitudeDeg, Mode=TwoWay}"
                               Minimum="-180" Maximum="180" FormatString="F4" />
              </StackPanel>
            </Grid>
            <TextBlock Text="Maidenhead grid square" />
            <TextBox Text="{Binding GridSquare, Mode=TwoWay}" MaxLength="8" />
            <TextBlock Text="Altitude ASL (m)" />
            <NumericUpDown Value="{Binding AltitudeMeters, Mode=TwoWay}"
                           Minimum="0" Maximum="9000"
                           Increment="0.1" FormatString="F1" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Tracking">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,4">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="Minimum elevation (°)" />
            <NumericUpDown Value="{Binding MinimumElevationDeg, Mode=TwoWay}"
                           Minimum="0" Maximum="90" FormatString="F1" />
            <TextBlock Text="Pass prediction window (hours)" />
            <NumericUpDown Value="{Binding PassPredictionHours, Mode=TwoWay}"
                           Minimum="6" Maximum="168" FormatString="F0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Used for the upcoming pass list and as defaults in the pass planner." />
            <TextBlock Text="TLE updates" Margin="0,8,0,0" />
            <ComboBox ItemsSource="{Binding TleAutoUpdateOptions}"
                      SelectedItem="{Binding TleAutoUpdateOption, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:TleAutoUpdateOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="TLEs can also be refreshed anytime from Satellites → Refresh TLEs." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Appearance">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,4">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="Theme" />
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding ThemePreference, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:AppThemePreference">
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="System follows your OS light/dark setting. The world map image stays light in all modes for now." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Voice">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,4">
          <StackPanel Spacing="10" MaxWidth="420">
            <CheckBox Content="Enable voice announcements"
                      IsChecked="{Binding VoiceAnnouncementsEnabled, Mode=TwoWay}" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Announces each enabled satellite once per pass when it crosses the elevation threshold while rising, for example: Alpha Oscar Zero Seven is rising." />
            <TextBlock Text="Announce at elevation (°)" Margin="0,8,0,0" />
            <NumericUpDown Value="{Binding AnnounceElevationDeg, Mode=TwoWay}"
                           Minimum="-10" Maximum="30"
                           Increment="0.5" FormatString="F1" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Default is -3°. The announcement fires when elevation rises through this value (negative values catch the satellite before it clears the horizon)." />
            <TextBlock Text="Voice" Margin="0,8,0,0" />
            <ComboBox ItemsSource="{Binding SpeechVoiceOptions}"
                      SelectedItem="{Binding SelectedSpeechVoice, Mode=TwoWay}"
                      IsEnabled="{Binding SpeechAvailable}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="services:SpeechVoiceOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       IsVisible="{Binding SpeechUnavailable}"
                       Text="Text-to-speech is not available on this system." />
            <TextBlock Text="Preview" Margin="0,8,0,0" />
            <TextBlock Text="{Binding VoicePreviewText}"
                       TextWrapping="Wrap"
                       FontStyle="Italic" />
            <Button Content="Test announcement"
                    Command="{Binding TestVoiceAnnouncementCommand}"
                    IsEnabled="{Binding SpeechAvailable}"
                    HorizontalAlignment="Left"
                    MinWidth="140" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Radio">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,4">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="{Binding ComPortConflictText}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ShowComPortConflict}" />
            <CheckBox Content="Enable radio control"
                      IsChecked="{Binding RigEnabled, Mode=TwoWay}" />
            <TextBlock Text="Radio driver" />
            <ComboBox ItemsSource="{Binding RigTypeChoices}"
                      SelectedItem="{Binding SelectedRigTypeChoice, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RigTypeOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Serial port" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox Grid.Column="0"
                        ItemsSource="{Binding AvailableComPorts}"
                        SelectedItem="{Binding SelectedRigComPort, Mode=TwoWay}"
                        PlaceholderText="Select COM port"
                        HorizontalAlignment="Stretch" />
              <Button Grid.Column="1"
                      Content="Refresh"
                      Command="{Binding RefreshComPortsCommand}"
                      MinWidth="72" />
            </Grid>
            <TextBlock Text="Baud rate" />
            <ComboBox ItemsSource="{Binding BaudRateOptions}"
                      SelectedItem="{Binding RigBaudRate, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" />
            <TextBlock Text="CI-V address (hex)" />
            <TextBox Text="{Binding RigCivAddress, Mode=TwoWay}"
                     Watermark="60" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="IC-9700 default A2, IC-910 default 7C (hex). Use 60 if your radio is set that way in the CI-V menu." />
            <TextBlock Text="Region" />
            <ComboBox ItemsSource="{Binding RigRegionChoices}"
                      SelectedItem="{Binding SelectedRigRegionChoice, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RigRegionOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="EU uses tone; USA uses tone squelch (subtone)." />
            <TextBlock Text="Start tracking at elevation (°)" Margin="0,8,0,0" />
            <NumericUpDown Value="{Binding RigTrackStartElevationDeg, Mode=TwoWay}"
                           Minimum="-90" Maximum="90"
                           Increment="0.5" FormatString="F1" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,-6,0,0"
                       Text="Default is -3°. Use negative values to start CAT before the satellite reaches the horizon (e.g. -10° or lower)." />
            <TextBlock Text="Doppler threshold FM (Hz)" />
            <NumericUpDown Value="{Binding RigDopplerThresholdFmHz, Mode=TwoWay}"
                           Minimum="0" Maximum="2000"
                           Increment="10" FormatString="F0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,-6,0,0"
                       Text="FM / ISS cross-band: lower = more CAT updates (default 50 Hz)." />
            <TextBlock Text="Doppler threshold SSB/CW (Hz)" />
            <NumericUpDown Value="{Binding RigDopplerThresholdLinearHz, Mode=TwoWay}"
                           Minimum="0" Maximum="500"
                           Increment="5" FormatString="F0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Frequencies are sent to the radio only when drift exceeds this interval (SatPC32-style)." />
            <TextBlock Text="CAT delay (ms)" />
            <NumericUpDown Value="{Binding RigCatDelayMs, Mode=TwoWay}"
                           Minimum="0" Maximum="500"
                           Increment="10" FormatString="F0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Minimum time between CI-V commands to protect the serial link." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Rotator">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,4">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="{Binding ComPortConflictText}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ShowComPortConflict}" />
            <CheckBox Content="Enable rotator"
                      IsChecked="{Binding RotatorEnabled, Mode=TwoWay}" />
            <TextBlock Text="Rotator type" />
            <ComboBox ItemsSource="{Binding RotatorTypeChoices}"
                      SelectedItem="{Binding SelectedRotatorTypeChoice, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RotatorTypeOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="GS-232 for Yaesu and many clones. EasyComm for SPID, M2, and other EasyComm-compatible controllers." />
            <TextBlock Text="Serial port" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox Grid.Column="0"
                        ItemsSource="{Binding AvailableComPorts}"
                        SelectedItem="{Binding SelectedComPort, Mode=TwoWay}"
                        PlaceholderText="Select COM port"
                        HorizontalAlignment="Stretch" />
              <Button Grid.Column="1"
                      Content="Refresh"
                      Command="{Binding RefreshComPortsCommand}"
                      MinWidth="72" />
            </Grid>
            <TextBlock Text="Baud rate" />
            <ComboBox ItemsSource="{Binding BaudRateOptions}"
                      SelectedItem="{Binding RotatorBaudRate, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" />
            <TextBlock Text="Azimuth range" />
            <ComboBox ItemsSource="{Binding AzimuthRangeChoices}"
                      SelectedItem="{Binding SelectedAzimuthRangeChoice, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RotatorAzimuthOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Elevation range" />
            <ComboBox ItemsSource="{Binding ElevationRangeChoices}"
                      SelectedItem="{Binding SelectedElevationRangeChoice, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RotatorElevationOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Start tracking at elevation (°)" Margin="0,8,0,0" />
            <NumericUpDown Value="{Binding RotatorTrackStartElevationDeg, Mode=TwoWay}"
                           Minimum="-90" Maximum="90"
                           Increment="0.5" FormatString="F1" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Default is -3° (below horizon). Range -90° to 90°. The rotator begins slewing when the tracked satellite rises above this elevation, and parks once it drops below." />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Park azimuth (°)" />
                <NumericUpDown Value="{Binding RotatorParkAzimuthDeg, Mode=TwoWay}"
                               Minimum="0" Maximum="450"
                               Increment="1" FormatString="F0" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Park elevation (°)" />
                <NumericUpDown Value="{Binding RotatorParkElevationDeg, Mode=TwoWay}"
                               Minimum="0" Maximum="180"
                               Increment="1" FormatString="F0" />
              </StackPanel>
            </Grid>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Park position is used when no satellite is above the tracking threshold. The focused pass or live satellite is tracked automatically." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Cloudlog">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,4">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       Text="Posts satellite TX/RX to Cloudlog CAT (API v2 /index.php/api/radio) when you select a satellite or frequencies update." />
            <CheckBox Content="Enable Cloudlog radio API (required for live updates)"
                      IsChecked="{Binding CloudlogEnabled, Mode=TwoWay}" />
            <TextBlock Text="Cloudlog base URL" />
            <TextBox Text="{Binding CloudlogBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="https://your.cloudlog.site" />
            <TextBlock Text="API key" />
            <TextBox Text="{Binding CloudlogApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="read/write API key" />
            <TextBlock Text="Radio name in Cloudlog" />
            <TextBox Text="{Binding CloudlogRadioName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="OscarWatch" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Default is OscarWatch. Must match a radio entry Cloudlog can assign QSOs to." />
            <TextBlock Text="Minimum update interval (ms)" />
            <NumericUpDown Value="{Binding CloudlogMinUpdateIntervalMs, Mode=TwoWay}"
                           Minimum="250" Maximum="60000"
                           Increment="250" FormatString="F0" />
            <Button Content="Test connection"
                    Click="OnTestCloudlogClick"
                    HorizontalAlignment="Left" />
            <TextBlock Text="{Binding CloudlogTestStatus}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       MinHeight="20"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
