<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        xmlns:models="using:OscarWatch.Core.Models"
        xmlns:services="using:OscarWatch.Core.Services"
        x:Class="OscarWatch.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="800" Height="520"
        MinWidth="760" MinHeight="360"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="0">
    <Border DockPanel.Dock="Bottom"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Cancel"
                Classes="dialog-footer"
                Click="OnCancelClick" />
        <Button Content="Save"
                Classes="dialog-footer accent"
                Click="OnSaveClick"
                IsDefault="True" />
      </StackPanel>
    </Border>

    <TabControl Margin="12,12,12,8">
      <TabControl.Styles>
        <Style Selector="TabItem">
          <Setter Property="FontSize" Value="14" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Padding" Value="10,7" />
        </Style>
        <Style Selector="TabItem TextBlock">
          <Setter Property="FontSize" Value="14" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TabItem ScrollViewer StackPanel > TextBlock">
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style Selector="TabItem ScrollViewer > TextBlock">
          <Setter Property="FontSize" Value="11" />
          <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style Selector="TabItem ScrollViewer > StackPanel">
          <Setter Property="Margin" Value="0,0,0,56" />
        </Style>
      </TabControl.Styles>
      <TabItem Header="Station">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="Display name" />
            <TextBox Text="{Binding DisplayName, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Latitude (°)" />
                <NumericUpDown Value="{Binding LatitudeDeg, Mode=TwoWay}"
                               Minimum="-90" Maximum="90" FormatString="F4" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Longitude (°)" />
                <NumericUpDown Value="{Binding LongitudeDeg, Mode=TwoWay}"
                               Minimum="-180" Maximum="180" FormatString="F4" />
              </StackPanel>
            </Grid>
            <TextBlock Text="Maidenhead grid square" />
            <TextBox Text="{Binding GridSquare, Mode=TwoWay}" MaxLength="8" />
            <TextBlock Text="Altitude ASL (m)" />
            <NumericUpDown Value="{Binding AltitudeMeters, Mode=TwoWay}"
                           Minimum="0" Maximum="9000"
                           Increment="0.1" FormatString="F1" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="TLE">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="TLE catalog source" />
            <ComboBox ItemsSource="{Binding TleSourceOptions}"
                      SelectedItem="{Binding TleSourceOption, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:TleSourceOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="OscarWatch is the default AMSAT-oriented catalog. AMSAT.org uses the published nasabare.txt set. Use a custom URL or local file if you maintain your own TLE set." />
            <TextBlock Text="Download URL"
                       IsVisible="{Binding ShowTleCustomUrl}" />
            <TextBox Text="{Binding TleCustomUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="{Binding TleCustomUrlWatermark}"
                     IsVisible="{Binding ShowTleCustomUrl}" />
            <TextBlock Text="Local TLE file"
                       IsVisible="{Binding ShowTleLocalFile}" />
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8"
                  IsVisible="{Binding ShowTleLocalFile}">
              <TextBox Grid.Column="0"
                       Text="{Binding TleLocalFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="Path to .txt or .tle file" />
              <Button Grid.Column="1"
                      Content="Browse…"
                      Click="OnBrowseTleFileClick" />
            </Grid>
            <TextBlock Text="TLE updates" Margin="0,8,0,0" />
            <ComboBox ItemsSource="{Binding TleAutoUpdateOptions}"
                      SelectedItem="{Binding TleAutoUpdateOption, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:TleAutoUpdateOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Automatic download applies to OscarWatch and custom URLs only. Local files are re-read when you save settings or choose Satellites → Refresh TLEs." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Tracking">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="Minimum elevation (°)" />
            <NumericUpDown Value="{Binding MinimumElevationDeg, Mode=TwoWay}"
                           Minimum="0" Maximum="90" FormatString="F1" />
            <TextBlock Text="Pass prediction window (hours)" />
            <NumericUpDown Value="{Binding PassPredictionHours, Mode=TwoWay}"
                           Minimum="6" Maximum="168" FormatString="F0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Used for the upcoming pass list and as defaults in the pass planner." />
            <CheckBox Content="Check for transponder database updates on startup"
                      IsChecked="{Binding TransponderDatabaseCheckOnStartup, Mode=TwoWay}"
                      Margin="0,8,0,0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Downloads tle.oscarwatch.org/satellite_database.json when updates are available. New satellites and modes are offered for merge; your local edits are kept unless you accept published changes." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Appearance">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="Theme" />
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding ThemePreference, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:AppThemePreference">
                  <TextBlock Text="{Binding}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="System follows your OS light/dark setting. The world map image stays light in all modes for now." />
            <CheckBox Content="Show footprint motion arrows"
                      IsChecked="{Binding ShowFootprintMotionArrows, Mode=TwoWay}"
                      Margin="0,8,0,0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Draws a small arrow inside each satellite footprint on the world map showing ground-track direction." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Voice">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <CheckBox Content="Enable voice announcements"
                      IsChecked="{Binding VoiceAnnouncementsEnabled, Mode=TwoWay}" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Announces each enabled satellite once per pass when it crosses the elevation threshold while rising, for example: Alpha Oscar Zero Seven is rising." />
            <TextBlock Text="Announce at elevation (°)" Margin="0,8,0,0" />
            <NumericUpDown Value="{Binding AnnounceElevationDeg, Mode=TwoWay}"
                           Minimum="-10" Maximum="30"
                           Increment="0.5" FormatString="F1" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Default is -3°. The announcement fires when elevation rises through this value (negative values catch the satellite before it clears the horizon)." />
            <TextBlock Text="Voice" Margin="0,8,0,0" />
            <ComboBox ItemsSource="{Binding SpeechVoiceOptions}"
                      SelectedItem="{Binding SelectedSpeechVoice, Mode=TwoWay}"
                      IsEnabled="{Binding SpeechAvailable}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="services:SpeechVoiceOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       IsVisible="{Binding SpeechUnavailable}"
                       Text="Text-to-speech is not available on this system." />
            <TextBlock Text="Preview" Margin="0,8,0,0" />
            <TextBlock Text="{Binding VoicePreviewText}"
                       TextWrapping="Wrap"
                       FontStyle="Italic" />
            <Button Content="Test announcement"
                    Command="{Binding TestVoiceAnnouncementCommand}"
                    IsEnabled="{Binding SpeechAvailable}"
                    HorizontalAlignment="Left"
                    MinWidth="140" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Radio">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="{Binding ComPortConflictText}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ShowComPortConflict}" />
            <CheckBox Content="Enable radio control"
                      IsChecked="{Binding RigEnabled, Mode=TwoWay}" />
            <CheckBox Content="Dual radio (required for FT-817 / FT-818 — separate downlink and uplink)"
                      IsChecked="{Binding DualRadioEnabled, Mode=TwoWay}"
                      Margin="0,4,0,0" />
            <StackPanel Spacing="10" IsVisible="{Binding ShowRigSingleConfig}">
              <TextBlock Text="Radio driver" />
              <ComboBox ItemsSource="{Binding RigTypeChoices}"
                        SelectedItem="{Binding SelectedRigTypeChoice, Mode=TwoWay}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:RigTypeOption">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="Serial port" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AvailableComPorts}"
                          SelectedItem="{Binding SelectedRigComPort, Mode=TwoWay}"
                          PlaceholderText="Select COM port"
                          HorizontalAlignment="Stretch" />
                <Button Grid.Column="1"
                        Content="Refresh"
                        Command="{Binding RefreshComPortsCommand}"
                        MinWidth="72" />
              </Grid>
              <TextBlock Text="Baud rate" />
              <ComboBox ItemsSource="{Binding RigBaudRateOptions}"
                        SelectedItem="{Binding RigBaudRate, Mode=TwoWay}"
                        HorizontalAlignment="Stretch" />
              <StackPanel Spacing="4" IsVisible="{Binding ShowRigCivAddress}">
                <TextBlock Text="CI-V address (hex)" />
                <TextBox Text="{Binding RigCivAddress, Mode=TwoWay}"
                         Watermark="60" />
                <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Text="IC-9700 default A2, IC-910 default 7C (hex). Use 60 if your radio is set that way in the CI-V menu." />
              </StackPanel>
              <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         IsVisible="{Binding ShowRigFt847CatHint}"
                         Text="FT-847: set CAT baud in radio menu #37 (typically 57600). Use the CAT/LINEAR jack with a level converter (e.g. CT-62)." />
              <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         IsVisible="{Binding ShowRigTs2000CatHint}"
                         Text="TS-2000: CAT 57600 8N1. SATL on for cross-band passes; VHF/UHF swapped automatically if Main is on the wrong band (TRACE off via CAT)." />
              <TextBlock Text="Region" />
              <ComboBox ItemsSource="{Binding RigRegionChoices}"
                        SelectedItem="{Binding SelectedRigRegionChoice, Mode=TwoWay}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:RigRegionOption">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         Text="EU uses tone; USA uses tone squelch (subtone)." />
              <TextBlock Text="CAT delay (ms)" />
              <NumericUpDown Value="{Binding RigCatDelayMs, Mode=TwoWay}"
                             Minimum="0" Maximum="500"
                             Increment="10" FormatString="F0" />
              <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         Text="Minimum time between CAT commands to protect the serial link." />
            </StackPanel>
            <StackPanel Spacing="12" IsVisible="{Binding ShowRigDualConfig}">
              <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Downlink radio" FontWeight="SemiBold" />
                  <TextBlock Text="Radio" />
                  <ComboBox ItemsSource="{Binding RigDualTypeChoices}"
                            SelectedItem="{Binding SelectedDownlinkRigTypeChoice, Mode=TwoWay}"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:RigTypeOption">
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="Serial port" />
                  <ComboBox ItemsSource="{Binding AvailableComPorts}"
                            SelectedItem="{Binding SelectedDownlinkComPort, Mode=TwoWay}"
                            PlaceholderText="Select COM port"
                            HorizontalAlignment="Stretch" />
                  <TextBlock Text="Baud rate" />
                  <ComboBox ItemsSource="{Binding RigBaudRateOptions}"
                            SelectedItem="{Binding DownlinkBaudRate, Mode=TwoWay}"
                            HorizontalAlignment="Stretch" />
                  <TextBlock Text="Region" />
                  <ComboBox ItemsSource="{Binding RigRegionChoices}"
                            SelectedItem="{Binding SelectedDownlinkRegionChoice, Mode=TwoWay}"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:RigRegionOption">
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="CAT delay (ms)" />
                  <NumericUpDown Value="{Binding DownlinkCatDelayMs, Mode=TwoWay}"
                                 Minimum="0" Maximum="500"
                                 Increment="10" FormatString="F0" />
                </StackPanel>
              </Border>
              <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Uplink radio" FontWeight="SemiBold" />
                  <TextBlock Text="Radio" />
                  <ComboBox ItemsSource="{Binding RigDualTypeChoices}"
                            SelectedItem="{Binding SelectedUplinkRigTypeChoice, Mode=TwoWay}"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:RigTypeOption">
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="Serial port" />
                  <ComboBox ItemsSource="{Binding AvailableComPorts}"
                            SelectedItem="{Binding SelectedUplinkComPort, Mode=TwoWay}"
                            PlaceholderText="Select COM port"
                            HorizontalAlignment="Stretch" />
                  <TextBlock Text="Baud rate" />
                  <ComboBox ItemsSource="{Binding RigBaudRateOptions}"
                            SelectedItem="{Binding UplinkBaudRate, Mode=TwoWay}"
                            HorizontalAlignment="Stretch" />
                  <TextBlock Text="Region" />
                  <ComboBox ItemsSource="{Binding RigRegionChoices}"
                            SelectedItem="{Binding SelectedUplinkRegionChoice, Mode=TwoWay}"
                            HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:RigRegionOption">
                        <TextBlock Text="{Binding Label}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="CAT delay (ms)" />
                  <NumericUpDown Value="{Binding UplinkCatDelayMs, Mode=TwoWay}"
                                 Minimum="0" Maximum="500"
                                 Increment="10" FormatString="F0" />
                </StackPanel>
              </Border>
              <Button Content="Refresh COM ports"
                      Command="{Binding RefreshComPortsCommand}"
                      HorizontalAlignment="Left"
                      MinWidth="140" />
            </StackPanel>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ShowRigFt817CatHint}"
                       Text="FT-817 / FT-818: enable Dual radio above. Match CAT baud to menu #14 (typically 38400) on each radio. One COM port per leg — downlink for RX, uplink for TX." />
            <CheckBox Content="Linear CW: keep receive in USB/LSB (transmit CW only)"
                      IsChecked="{Binding RigCwKeepSidebandDownlink, Mode=TwoWay}"
                      Margin="0,8,0,0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Applies when the frequency panel is set to CW on linear SSB satellites. Checked is the usual split (CW TX, USB/LSB RX). Unchecked sets both VFOs to CW." />
            <TextBlock Text="Doppler threshold FM (Hz)" Margin="0,8,0,0" />
            <NumericUpDown Value="{Binding RigDopplerThresholdFmHz, Mode=TwoWay}"
                           Minimum="0" Maximum="2000"
                           Increment="10" FormatString="F0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,-6,0,0"
                       Text="FM / ISS cross-band: lower = more CAT updates (default 350 Hz)." />
            <TextBlock Text="Doppler threshold SSB/CW (Hz)" Margin="0,8,0,0" />
            <NumericUpDown Value="{Binding RigDopplerThresholdLinearHz, Mode=TwoWay}"
                           Minimum="0" Maximum="500"
                           Increment="5" FormatString="F0" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Frequencies are sent to the radio only when drift exceeds this interval (SatPC32-style)." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Rotator">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock Text="{Binding ComPortConflictText}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ShowComPortConflict}" />
            <CheckBox Content="Enable rotator"
                      IsChecked="{Binding RotatorEnabled, Mode=TwoWay}" />
            <TextBlock Text="Rotator type" />
            <ComboBox ItemsSource="{Binding RotatorTypeChoices}"
                      SelectedItem="{Binding SelectedRotatorTypeChoice, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RotatorTypeOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="GS-232 for Yaesu and many clones. EasyComm for SPID, M2, and other EasyComm-compatible controllers." />
            <TextBlock Text="Serial port" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox Grid.Column="0"
                        ItemsSource="{Binding AvailableComPorts}"
                        SelectedItem="{Binding SelectedComPort, Mode=TwoWay}"
                        PlaceholderText="Select COM port"
                        HorizontalAlignment="Stretch" />
              <Button Grid.Column="1"
                      Content="Refresh"
                      Command="{Binding RefreshComPortsCommand}"
                      MinWidth="72" />
            </Grid>
            <TextBlock Text="Baud rate" />
            <ComboBox ItemsSource="{Binding RotatorBaudRateOptions}"
                      SelectedItem="{Binding RotatorBaudRate, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" />
            <TextBlock Text="Azimuth range" />
            <ComboBox ItemsSource="{Binding AzimuthRangeChoices}"
                      SelectedItem="{Binding SelectedAzimuthRangeChoice, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RotatorAzimuthOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <CheckBox Content="Smart 450° azimuth (shortest path over north)"
                      IsChecked="{Binding RotatorSmartAzimuth450, Mode=TwoWay}"
                      IsEnabled="{Binding IsRotatorSmartAzimuth450Enabled}" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="On 450° rotators (e.g. Yaesu G-5500), commands 361–450° avoid a long slew back through 0° when tracking passes over north." />
            <TextBlock Text="Elevation range" />
            <ComboBox ItemsSource="{Binding ElevationRangeChoices}"
                      SelectedItem="{Binding SelectedElevationRangeChoice, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RotatorElevationOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Start tracking at elevation (°)" Margin="0,8,0,0" />
            <NumericUpDown Value="{Binding RotatorTrackStartElevationDeg, Mode=TwoWay}"
                           Minimum="-90" Maximum="90"
                           Increment="0.5" FormatString="F1" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Default is -3° (below horizon). Range -90° to 90°. The rotator begins slewing when the tracked satellite rises above this elevation, and parks once it drops below." />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,8,0,0">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Park azimuth (°)" />
                <NumericUpDown Value="{Binding RotatorParkAzimuthDeg, Mode=TwoWay}"
                               Minimum="0" Maximum="450"
                               Increment="1" FormatString="F0" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Park elevation (°)" />
                <NumericUpDown Value="{Binding RotatorParkElevationDeg, Mode=TwoWay}"
                               Minimum="0" Maximum="180"
                               Increment="1" FormatString="F0" />
              </StackPanel>
            </Grid>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Park position is used when no satellite is above the tracking threshold. The focused pass or live satellite is tracked automatically." />
            <TextBlock Text="Calibration offsets (°)" Margin="0,8,0,0" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Azimuth offset" />
                <NumericUpDown Value="{Binding RotatorAzimuthOffsetDeg, Mode=TwoWay}"
                               Minimum="-180" Maximum="180"
                               Increment="0.1" FormatString="F1" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Elevation offset" />
                <NumericUpDown Value="{Binding RotatorElevationOffsetDeg, Mode=TwoWay}"
                               Minimum="-45" Maximum="45"
                               Increment="0.1" FormatString="F1" />
              </StackPanel>
            </Grid>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Added to pass tracking and manual rotate commands (not park). Use positive values if the beam stops short of the target; negative if it overshoots." />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Recording">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <CheckBox Content="Enable automatic pass recording"
                      IsChecked="{Binding PassRecordingEnabled, Mode=TwoWay}" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Records WAV audio from the selected input device while the focused satellite is above the start elevation. Files are saved with UTC timestamps." />
            <TextBlock Text="Input device" Margin="0,8,0,0" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <ComboBox Grid.Column="0"
                        ItemsSource="{Binding RecordingDeviceOptions}"
                        SelectedItem="{Binding SelectedRecordingDevice, Mode=TwoWay}"
                        IsEnabled="{Binding RecordingAvailable}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:RecordingDeviceOption">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <Button Grid.Column="1"
                      Content="Refresh"
                      Command="{Binding RefreshRecordingDevicesCommand}" />
            </Grid>
            <TextBlock Text="Format" Margin="0,8,0,0" />
            <ComboBox ItemsSource="{Binding RecordingFormatOptions}"
                      SelectedItem="{Binding SelectedRecordingFormat, Mode=TwoWay}"
                      IsEnabled="{Binding RecordingAvailable}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RecordingFormatOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Start recording at elevation (°)" Margin="0,8,0,0" />
            <NumericUpDown Value="{Binding RecordingStartElevationDeg, Mode=TwoWay}"
                           Minimum="-10" Maximum="90"
                           Increment="0.5" FormatString="F1" />
            <TextBlock Text="Stop recording below elevation (°)" />
            <NumericUpDown Value="{Binding RecordingStopElevationDeg, Mode=TwoWay}"
                           Minimum="-10" Maximum="90"
                           Increment="0.5" FormatString="F1" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Stop elevation should be at or below the start elevation to avoid flapping near the threshold." />
            <TextBlock Text="Output folder" Margin="0,8,0,0" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0"
                       Text="{Binding RecordingOutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="Default: %AppData%/OscarWatch/recordings" />
              <Button Grid.Column="1"
                      Content="Browse…"
                      Click="OnBrowseRecordingFolderClick" />
            </Grid>
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       IsVisible="{Binding RecordingUnavailable}"
                       Text="{Binding RecordingUnavailableText}" />
            <Button Content="Test recording (5 s)"
                    Command="{Binding TestRecordingCommand}"
                    HorizontalAlignment="Left"
                    MinWidth="160" />
            <TextBlock Text="{Binding RecordingTestStatus}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Cloudlog">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8,4,0">
          <StackPanel Spacing="10" MaxWidth="420">
            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       Text="Posts satellite TX/RX to Cloudlog CAT (API v2 /index.php/api/radio) when you select a satellite or frequencies update." />
            <CheckBox Content="Enable Cloudlog radio API (required for live updates)"
                      IsChecked="{Binding CloudlogEnabled, Mode=TwoWay}" />
            <TextBlock Text="Cloudlog base URL" />
            <TextBox Text="{Binding CloudlogBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="https://your.cloudlog.site" />
            <TextBlock Text="API key" />
            <TextBox Text="{Binding CloudlogApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="read/write API key" />
            <TextBlock Text="Radio name in Cloudlog" />
            <TextBox Text="{Binding CloudlogRadioName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="OscarWatch" />
            <TextBlock Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Text="Default is OscarWatch. Must match a radio entry Cloudlog can assign QSOs to." />
            <TextBlock Text="Minimum update interval (ms)" />
            <NumericUpDown Value="{Binding CloudlogMinUpdateIntervalMs, Mode=TwoWay}"
                           Minimum="250" Maximum="60000"
                           Increment="250" FormatString="F0" />
            <Button Content="Test connection"
                    Click="OnTestCloudlogClick"
                    HorizontalAlignment="Left" />
            <TextBlock Text="{Binding CloudlogTestStatus}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       MinHeight="20"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
