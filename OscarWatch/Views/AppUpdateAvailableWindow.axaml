<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:OscarWatch.Localization"
        x:Class="OscarWatch.Views.AppUpdateAvailableWindow"
        Title="{loc:Localize Key=Update.Available.Title}"
        Width="420" SizeToContent="Height"
        MinWidth="360" MaxHeight="280"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="20">
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,16,0,0">
      <Button x:Name="RemindLaterButton"
              Content="{loc:Localize Key=Update.RemindLater}"
              Classes="dialog-footer"
              Click="OnRemindLaterClick" />
      <Button x:Name="SkipButton"
              Content="{loc:Localize Key=Update.SkipVersion}"
              Classes="dialog-footer"
              Click="OnSkipClick" />
      <Button x:Name="ViewReleaseButton"
              Content="{loc:Localize Key=Update.ViewRelease}"
              Classes="dialog-footer accent"
              Click="OnViewReleaseClick"
              IsDefault="True" />
    </StackPanel>
    <TextBlock x:Name="MessageText"
               TextWrapping="Wrap"
               FontSize="13"
               LineHeight="20" />
  </DockPanel>
</Window>
