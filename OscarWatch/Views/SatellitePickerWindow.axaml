<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        x:Class="OscarWatch.Views.SatellitePickerWindow"
        x:DataType="vm:SatellitePickerViewModel"
        Title="Select Satellites"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
      <TextBox Watermark="Search satellites…" Text="{Binding SearchText}" />
      <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
        <Button Content="Select All" Command="{Binding SelectAllCommand}" />
        <Button Grid.Column="1" Content="Select None" Command="{Binding SelectNoneCommand}" />
        <Grid Grid.Column="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
          <TextBlock Text="Show" VerticalAlignment="Center" />
          <ComboBox Grid.Column="1"
                    MinWidth="120"
                    ItemsSource="{Binding SelectionFilterChoices}"
                    SelectedItem="{Binding SelectedSelectionFilterChoice, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:SatellitePickerFilterOption">
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>
      </Grid>
    </StackPanel>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button Content="Cancel" Classes="dialog-footer" Click="OnCancelClick" />
      <Button Content="OK" Click="OnOkClick" Classes="accent" />
    </StackPanel>
    <ListBox ItemsSource="{Binding Satellites}" MinHeight="360">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:SatelliteItemViewModel">
          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsVisible}">
            <CheckBox IsChecked="{Binding IsEnabled}" />
            <TextBlock VerticalAlignment="Center" Text="{Binding Name}" FontWeight="SemiBold" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Text="{Binding NoradId}" />
            <TextBlock VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Foreground="{DynamicResource StaleTleForegroundBrush}"
                       Text="Stale TLE"
                       IsVisible="{Binding IsStale}" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</Window>
