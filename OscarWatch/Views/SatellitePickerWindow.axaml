<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        x:Class="OscarWatch.Views.SatellitePickerWindow"
        x:DataType="vm:SatellitePickerViewModel"
        Title="Select Satellites"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,8">
      <TextBox Watermark="Search satellites…" Text="{Binding SearchText}" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Select all" Command="{Binding SelectAllCommand}" />
        <Button Content="Select none" Command="{Binding SelectNoneCommand}" />
      </StackPanel>
    </StackPanel>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button Content="Cancel" Click="OnCancelClick" />
      <Button Content="OK" Click="OnOkClick" Classes="accent" />
    </StackPanel>
    <ListBox ItemsSource="{Binding Satellites}" MinHeight="360">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:SatelliteItemViewModel">
          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsVisible}">
            <CheckBox IsChecked="{Binding IsEnabled}" />
            <TextBlock VerticalAlignment="Center" Text="{Binding Name}" FontWeight="SemiBold" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Text="{Binding NoradId}" />
            <TextBlock VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Foreground="{DynamicResource StaleTleForegroundBrush}"
                       Text="Stale TLE"
                       IsVisible="{Binding IsStale}" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</Window>
