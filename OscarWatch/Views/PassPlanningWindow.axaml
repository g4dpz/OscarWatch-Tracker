<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        xmlns:models="using:OscarWatch.Core.Models"
        x:Class="OscarWatch.Views.PassPlanningWindow"
        x:DataType="vm:PassPlanningViewModel"
        Title="Pass planner"
        Width="820" Height="560"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="12">
    <DockPanel.Styles>
      <Style Selector="Expander">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      </Style>
    </DockPanel.Styles>
    <Border DockPanel.Dock="Bottom"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="0,10,0,0"
            Margin="0,10,0,0">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{Binding StatusText}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Content="Use as active station" Click="OnUseActiveClick" Classes="accent" />
          <Button Content="Close" Click="OnCloseClick" MinWidth="80" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid RowDefinitions="Auto,*"
          HorizontalAlignment="Stretch">
      <Expander Grid.Row="0"
                Header="Station &amp; filters"
                IsExpanded="True"
                Padding="0,0,0,8"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                MinWidth="0">
        <StackPanel Spacing="8"
                    HorizontalAlignment="Stretch"
                    MinWidth="0">
          <Grid ColumnDefinitions="*,Auto,Auto,2*"
                ColumnSpacing="8"
                HorizontalAlignment="Stretch"
                MinWidth="0">
            <ComboBox Grid.Column="0"
                      HorizontalAlignment="Stretch"
                      MinWidth="0"
                      ItemsSource="{Binding Stations}"
                      SelectedItem="{Binding SelectedStation, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:StationProfile">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="1" Content="Add" Command="{Binding AddStationCommand}" />
            <Button Grid.Column="2"
                    Content="Delete"
                    Command="{Binding DeleteStationCommand}"
                    IsEnabled="{Binding CanDeleteStation}" />
            <TextBox Grid.Column="3"
                     HorizontalAlignment="Stretch"
                     MinWidth="0"
                     Watermark="Display name"
                     Text="{Binding StationDisplayName, Mode=TwoWay}" />
          </Grid>

          <Grid ColumnDefinitions="*,*,*,*,Auto"
                ColumnSpacing="8"
                HorizontalAlignment="Stretch"
                MinWidth="0">
            <StackPanel Grid.Column="0" Spacing="2" MinWidth="0">
              <TextBlock Text="Latitude (°)" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <NumericUpDown HorizontalAlignment="Stretch"
                             Value="{Binding StationLatitudeDeg, Mode=TwoWay}"
                             Minimum="-90" Maximum="90"
                             FormatString="F4" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
              <TextBlock Text="Longitude (°)" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <NumericUpDown HorizontalAlignment="Stretch"
                             Value="{Binding StationLongitudeDeg, Mode=TwoWay}"
                             Minimum="-180" Maximum="180"
                             FormatString="F4" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="2" MinWidth="0">
              <TextBlock Text="Maidenhead" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <TextBox HorizontalAlignment="Stretch"
                       Text="{Binding StationGridSquare, Mode=TwoWay}" MaxLength="8" />
            </StackPanel>
            <StackPanel Grid.Column="3" Spacing="2" MinWidth="0">
              <TextBlock Text="Alt ASL (m)" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <NumericUpDown HorizontalAlignment="Stretch"
                             Value="{Binding StationAltitudeMeters, Mode=TwoWay}"
                             Minimum="0" Maximum="9000"
                             Increment="0.1" FormatString="F1" />
            </StackPanel>
            <Button Grid.Column="4"
                    Content="Refresh passes"
                    Command="{Binding RefreshPassesCommand}"
                    VerticalAlignment="Bottom"
                    MinWidth="110" />
          </Grid>

          <Grid ColumnDefinitions="*,*,*,2*"
                ColumnSpacing="8"
                HorizontalAlignment="Stretch"
                MinWidth="0">
            <StackPanel Grid.Column="0" Spacing="2" MinWidth="0">
              <TextBlock Text="Min elevation (°)" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <NumericUpDown HorizontalAlignment="Stretch"
                             Value="{Binding FilterMinElevationDeg, Mode=TwoWay}"
                             Minimum="0" Maximum="90" FormatString="F1" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
              <TextBlock Text="Min duration (min)" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <NumericUpDown HorizontalAlignment="Stretch"
                             Value="{Binding FilterMinDurationMinutes, Mode=TwoWay}"
                             Minimum="0" Maximum="60" FormatString="0" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="2" MinWidth="0">
              <TextBlock Text="Hours ahead" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <NumericUpDown HorizontalAlignment="Stretch"
                             Value="{Binding FilterPredictionHours, Mode=TwoWay}"
                             Minimum="6" Maximum="168" FormatString="0" />
            </StackPanel>
            <TextBlock Grid.Column="3"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,6"
                       FontSize="10"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Stretch"
                       Text="Filters apply to this list and the main window when you close." />
          </Grid>
        </StackPanel>
      </Expander>

      <DockPanel Grid.Row="1"
                 HorizontalAlignment="Stretch"
                 LastChildFill="True"
                 MinWidth="0">
        <TextBlock DockPanel.Dock="Top"
                   Text="Passes"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <DataGrid ItemsSource="{Binding Passes}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  CanUserResizeColumns="False"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  MinHeight="120"
                  BorderThickness="0">
          <DataGrid.Styles>
            <Style Selector="DataGridColumnHeader">
              <Setter Property="FontWeight" Value="SemiBold" />
              <Setter Property="FontSize" Value="11" />
              <Setter Property="Padding" Value="8,6" />
              <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
            <Style Selector="DataGridCell">
              <Setter Property="Padding" Value="8,4" />
              <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
          </DataGrid.Styles>
          <DataGrid.Columns>
            <DataGridTextColumn Header="Satellite"
                                Binding="{Binding SatelliteName, DataType={x:Type vm:PassPlanningPassRow}}"
                                Width="90"
                                MinWidth="80" />
            <DataGridTextColumn Header="AOS – LOS"
                                Binding="{Binding AosLosLine, DataType={x:Type vm:PassPlanningPassRow}}"
                                Width="178"
                                MinWidth="160"
                                FontFamily="Consolas,Courier New,monospace" />
            <DataGridTextColumn Header="TCA"
                                Binding="{Binding TcaLocal, DataType={x:Type vm:PassPlanningPassRow}}"
                                Width="88"
                                MinWidth="72"
                                FontFamily="Consolas,Courier New,monospace" />
            <DataGridTextColumn Header="Azimuth"
                                Binding="{Binding AzimuthSummary, DataType={x:Type vm:PassPlanningPassRow}}"
                                Width="132"
                                MinWidth="120"
                                FontFamily="Consolas,Courier New,monospace" />
            <DataGridTextColumn Header="Max el"
                                Binding="{Binding MaxEl, DataType={x:Type vm:PassPlanningPassRow}}"
                                Width="92"
                                MinWidth="84"
                                FontFamily="Consolas,Courier New,monospace" />
            <DataGridTextColumn Header="Duration"
                                Binding="{Binding Duration, DataType={x:Type vm:PassPlanningPassRow}}"
                                Width="96"
                                MinWidth="88"
                                FontFamily="Consolas,Courier New,monospace" />
            <DataGridTemplateColumn Header="Calendar"
                                    Width="128"
                                    MinWidth="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:PassPlanningPassRow">
                  <Button Content="Add to Calendar"
                          FontSize="10"
                          Padding="6,3"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Tag="{Binding}"
                          Click="OnExportSatelliteClick"
                          ToolTip.Tip="Export all passes for this satellite to an iCalendar (.ics) file" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
