<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        xmlns:loc="using:OscarWatch.Localization"
        xmlns:ctrl="using:OscarWatch.Controls"
        x:Class="OscarWatch.Views.PassVisualizerWindow"
        x:DataType="vm:PassVisualizerViewModel"
        Title="{loc:Localize Key=Window.PassVisualizer.Title}"
        Width="480"
        Height="500"
        MinWidth="400"
        MinHeight="400"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="14"
        RowDefinitions="Auto,*,Auto"
        RowSpacing="12"
        x:Name="ScreenshotRoot">
    <StackPanel Grid.Row="0" Spacing="8">
      <TextBlock Text="{Binding HeadingText}"
                 FontSize="18"
                 FontWeight="SemiBold"
                 TextWrapping="Wrap" />
      <TextBlock Text="{Binding SubtitleText}"
                 FontSize="12"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" />
    </StackPanel>

    <Grid Grid.Row="1"
          RowDefinitions="Auto,*"
          RowSpacing="6"
          MinHeight="220">
      <TextBlock Grid.Row="0"
                 Text="{Binding PlotHeader}"
                 FontWeight="SemiBold"
                 FontSize="12"
                 TextWrapping="Wrap" />
      <ctrl:PassPolarPlotControl Grid.Row="1"
                                 PlotData="{Binding PlotData}"
                                 MinimumElevationDeg="{Binding MinimumElevationDeg}"
                                 UseUtcTime="{Binding UseUtcTime}"
                                 Use24HourClock="{Binding Use24HourClock}"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch" />
    </Grid>

    <Border Grid.Row="2"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="0,12,0,0">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="22" Height="3" Background="#D4A017" VerticalAlignment="Center" />
            <TextBlock Text="{loc:Localize Key=Mutual.Visualizer.Legend.Sunlit}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="22" Height="3" Background="#E05252" VerticalAlignment="Center" />
            <TextBlock Text="{loc:Localize Key=Mutual.Visualizer.Legend.Eclipse}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Content="{loc:Localize Key=Mutual.Visualizer.Screenshot}"
                  Click="OnScreenshotClick"
                  MinWidth="100" />
          <Button Content="{loc:Localize Key=Common.Close}"
                  Click="OnCloseClick"
                  MinWidth="80" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
