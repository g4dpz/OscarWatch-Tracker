<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        xmlns:loc="using:OscarWatch.Localization"
        xmlns:ctrl="using:OscarWatch.Controls"
        x:Class="OscarWatch.Views.PassVisualizerWindow"
        x:DataType="vm:PassVisualizerViewModel"
        Title="{loc:Localize Key=Window.PassVisualizer.Title}"
        Width="480"
        SizeToContent="Height"
        MinWidth="400"
        MaxHeight="700"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="14" Spacing="12" x:Name="ScreenshotRoot">
    <StackPanel Spacing="8">
      <TextBlock Text="{Binding HeadingText}"
                 FontSize="18"
                 FontWeight="SemiBold"
                 TextWrapping="Wrap" />
      <TextBlock Text="{Binding SubtitleText}"
                 FontSize="12"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" />
    </StackPanel>

    <StackPanel Spacing="6">
      <TextBlock Text="{Binding PlotHeader}"
                 FontWeight="SemiBold"
                 FontSize="12"
                 TextWrapping="Wrap" />
      <ctrl:PassPolarPlotControl PlotData="{Binding PlotData}"
                                 MinimumElevationDeg="{Binding MinimumElevationDeg}"
                                 UseUtcTime="{Binding UseUtcTime}"
                                 Use24HourClock="{Binding Use24HourClock}"
                                 Height="300"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Top" />
    </StackPanel>

    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="0,12,0,0">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="22" Height="3" Background="#D4A017" VerticalAlignment="Center" />
            <TextBlock Text="{loc:Localize Key=Mutual.Visualizer.Legend.Sunlit}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="22" Height="3" Background="#E05252" VerticalAlignment="Center" />
            <TextBlock Text="{loc:Localize Key=Mutual.Visualizer.Legend.Eclipse}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Content="{loc:Localize Key=Mutual.Visualizer.Screenshot}"
                  Click="OnScreenshotClick"
                  MinWidth="100" />
          <Button Content="{loc:Localize Key=Common.Close}"
                  Click="OnCloseClick"
                  MinWidth="80" />
        </StackPanel>
      </Grid>
    </Border>
  </StackPanel>
</Window>
