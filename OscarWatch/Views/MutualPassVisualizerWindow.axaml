<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        xmlns:loc="using:OscarWatch.Localization"
        xmlns:ctrl="using:OscarWatch.Controls"
        x:Class="OscarWatch.Views.MutualPassVisualizerWindow"
        x:DataType="vm:MutualPassVisualizerViewModel"
        Title="{loc:Localize Key=Window.MutualPassVisualizer.Title}"
        Width="920"
        Height="560"
        MinWidth="760"
        MinHeight="480"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="14"
        RowDefinitions="Auto,*,Auto"
        RowSpacing="12"
        x:Name="ScreenshotRoot">
    <StackPanel Grid.Row="0" Spacing="8">
      <TextBlock Text="{Binding HeadingText}"
                 FontSize="18"
                 FontWeight="SemiBold"
                 TextWrapping="Wrap" />
      <TextBlock Text="{Binding SubtitleText}"
                 FontSize="12"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource ThemeSecondaryForegroundBrush}" />
      <StackPanel Orientation="Horizontal" Spacing="20">
        <CheckBox IsChecked="{Binding ShowFullWestPass, Mode=TwoWay}"
                  Content="{Binding WestFullPassLabel}"
                  Foreground="#7EB8FF" />
        <CheckBox IsChecked="{Binding ShowFullEastPass, Mode=TwoWay}"
                  Content="{Binding EastFullPassLabel}"
                  Foreground="#C59BFF" />
      </StackPanel>
    </StackPanel>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,*"
          ColumnSpacing="16"
          MinHeight="220">
      <Grid Grid.Column="0"
            RowDefinitions="Auto,*"
            RowSpacing="6">
        <TextBlock Grid.Row="0"
                   Text="{Binding WestPlotHeader}"
                   FontWeight="SemiBold"
                   FontSize="12"
                   TextWrapping="Wrap" />
        <ctrl:PassPolarPlotControl Grid.Row="1"
                                   PlotData="{Binding WestPlotData}"
                                   MinimumElevationDeg="{Binding MinimumElevationDeg}"
                                   UseUtcTime="{Binding UseUtcTime}"
                                   Use24HourClock="{Binding Use24HourClock}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
      </Grid>
      <Grid Grid.Column="1"
            RowDefinitions="Auto,*"
            RowSpacing="6">
        <TextBlock Grid.Row="0"
                   Text="{Binding EastPlotHeader}"
                   FontWeight="SemiBold"
                   FontSize="12"
                   TextWrapping="Wrap" />
        <ctrl:PassPolarPlotControl Grid.Row="1"
                                   PlotData="{Binding EastPlotData}"
                                   MinimumElevationDeg="{Binding MinimumElevationDeg}"
                                   UseUtcTime="{Binding UseUtcTime}"
                                   Use24HourClock="{Binding Use24HourClock}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch" />
      </Grid>
    </Grid>

    <Border Grid.Row="2"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="0,12,0,0">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="14" Height="14" Background="#3DBB6D" CornerRadius="2" />
            <TextBlock Text="{loc:Localize Key=Mutual.Visualizer.Legend.Aos}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="14" Height="14" Background="#E69F00" CornerRadius="7" />
            <TextBlock Text="{loc:Localize Key=Mutual.Visualizer.Legend.Los}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="22" Height="3" Background="#D4A017" VerticalAlignment="Center" />
            <TextBlock Text="{loc:Localize Key=Mutual.Visualizer.Legend.Sunlit}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Border Width="22" Height="3" Background="#E05252" VerticalAlignment="Center" />
            <TextBlock Text="{loc:Localize Key=Mutual.Visualizer.Legend.Eclipse}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Content="{loc:Localize Key=Mutual.Visualizer.Screenshot}"
                  Click="OnScreenshotClick"
                  MinWidth="100" />
          <Button Content="{loc:Localize Key=Common.Close}"
                  Click="OnCloseClick"
                  MinWidth="80" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
