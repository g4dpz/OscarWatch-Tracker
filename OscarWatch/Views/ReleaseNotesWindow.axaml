<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:OscarWatch.Localization"
        x:Class="OscarWatch.Views.ReleaseNotesWindow"
        Title="{loc:Localize Key=ReleaseNotes.Title}"
        Width="560" Height="480"
        MinWidth="440" MinHeight="360"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,12,0,0">
      <Button Content="{loc:Localize Key=ReleaseNotes.ViewOnGitHub}"
              Classes="dialog-footer"
              Click="OnViewOnGitHubClick" />
      <Button Content="{loc:Localize Key=Common.Close}"
              Classes="dialog-footer"
              Click="OnCloseClick"
              IsDefault="True" />
    </StackPanel>
    <TextBlock x:Name="HeadingText"
               DockPanel.Dock="Top"
               FontSize="16"
               FontWeight="SemiBold"
               TextWrapping="Wrap"
               Margin="0,0,0,8" />
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="BodyPanel" Spacing="0" />
    </ScrollViewer>
  </DockPanel>
</Window>
