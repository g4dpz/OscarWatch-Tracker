<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:OscarWatch.Localization"
        x:Class="OscarWatch.Views.AboutWindow"
        Title="{loc:Localize Key=About.Title}"
        Width="440" Height="480"
        MinWidth="360" MinHeight="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <DockPanel Margin="20">
    <Border DockPanel.Dock="Bottom"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Padding="0,12,0,0"
            Margin="0,16,0,0">
      <Button Content="{loc:Localize Key=Common.Ok}"
              Classes="dialog-footer"
              HorizontalAlignment="Right"
              Click="OnOkClick"
              IsDefault="True" />
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="12" Margin="0,0,14,0">
      <TextBlock x:Name="TitleText"
                 Text="{loc:Localize Key=App.Title}"
                 FontSize="22"
                 FontWeight="SemiBold" />
      <TextBlock x:Name="VersionText"
                 FontSize="13"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      <TextBlock TextWrapping="Wrap"
                 FontSize="13"
                 LineHeight="20"
                 Text="{loc:Localize Key=About.Description}" />
      <TextBlock TextWrapping="Wrap"
                 FontSize="12"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 Text="{loc:Localize Key=About.TleSource}" />
      <TextBlock Text="{loc:Localize Key=About.Github}"
                 FontSize="12"
                 Foreground="{DynamicResource SystemAccentColorBrush}"
                 TextDecorations="Underline"
                 Cursor="Hand"
                 PointerPressed="OnGitHubRepoClick" />
      <TextBlock TextWrapping="Wrap"
                 FontSize="12"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 Text="{loc:Localize Key=About.Copyright}" />
      <TextBlock TextWrapping="Wrap"
                 FontSize="12"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 Text="{loc:Localize Key=About.License}" />
      <TextBlock TextWrapping="Wrap"
                 FontSize="13"
                 LineHeight="20"
                 Margin="0,4,0,0"
                 Text="{loc:Localize Key=About.SupportIntro}" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="{loc:Localize Key=About.SponsorGithub}"
                Classes="dialog-footer"
                Click="OnGitHubSponsorsClick"
                MinWidth="140" />
        <Button Content="{loc:Localize Key=About.PayPal}"
                Classes="dialog-footer"
                Click="OnPayPalClick" />
        <Button Content="{loc:Localize Key=About.Supporters}"
                Classes="dialog-footer"
                Click="OnGitHubContributorsClick"
                MinWidth="120" />
      </StackPanel>
      <TextBlock TextWrapping="Wrap"
                 FontSize="12"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 Text="{loc:Localize Key=About.DonateNote}" />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
