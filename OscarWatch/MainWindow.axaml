<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        xmlns:ctrl="using:OscarWatch.Controls"
        xmlns:theme="using:OscarWatch.Theme"
        x:Class="OscarWatch.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="OscarWatch"
        Width="1280" Height="556">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_Close" Command="{Binding CloseApplicationCommand}" />
      </MenuItem>
      <MenuItem Header="_Satellites">
        <MenuItem Header="_Select Satellites" Command="{Binding OpenSatellitesCommand}" />
        <MenuItem Header="_Manage Transponder Database" Command="{Binding OpenSatelliteDatabaseCommand}" />
        <MenuItem Header="_Refresh TLEs" Command="{Binding RefreshTlesCommand}" />
      </MenuItem>
      <MenuItem Header="_Passes">
        <MenuItem Header="_Pass Planner" Command="{Binding OpenPassPlanningCommand}" />
        <MenuItem Header="_Mutual Pass Planner" Command="{Binding OpenMutualPassFinderCommand}" />
      </MenuItem>
      <MenuItem Header="_Settings" Command="{Binding OpenSettingsCommand}" />
      <MenuItem Header="_Help">
        <MenuItem Header="_About OscarWatch" Command="{Binding OpenAboutCommand}" />
        <MenuItem Header="Open _logs folder" Command="{Binding OpenLogsFolderCommand}" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            Padding="8,4">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding UtcClock}"
                   VerticalAlignment="Center"
                   FontFamily="Consolas,Courier New,monospace"
                   Foreground="{DynamicResource ThemeForegroundBrush}" />
        <TextBlock Text="{Binding StatusText}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource ThemeForegroundBrush}" />
      </DockPanel>
    </Border>

    <Grid ColumnDefinitions="*,320" ClipToBounds="False">
      <Panel Grid.Column="0" ClipToBounds="False">
        <ctrl:WorldMapControl TabIndex="1"
                              ZIndex="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ClipToBounds="True"
                              TrackStates="{Binding LiveStates}"
                              GroundStation="{Binding GroundStation}"
                              FocusedNoradId="{Binding FocusedNoradId, Mode=TwoWay}" />
        <ctrl:FrequencyOverlayControl DataContext="{Binding Frequencies}"
                                      ZIndex="10"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      Margin="{Binding OverlayMargin}"
                                      IsHitTestVisible="True" />
      </Panel>

      <Border Grid.Column="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="1,0,0,0"
              Padding="8">
        <Grid RowDefinitions="Auto,Auto,Auto,*"
              HorizontalAlignment="Stretch">
          <Grid.Styles>
            <Style Selector="Expander">
              <Setter Property="HorizontalAlignment" Value="Stretch" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
            <Style Selector="Border.live-panel">
              <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
              <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="CornerRadius" Value="6" />
              <Setter Property="Padding" Value="10,8" />
            </Style>
            <Style Selector="TextBlock.live-panel-label">
              <Setter Property="FontSize" Value="11" />
              <Setter Property="FontWeight" Value="SemiBold" />
              <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </Style>
          </Grid.Styles>
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0"
                       Text="Live"
                       FontWeight="SemiBold"
                       FontSize="14"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="{Binding StandbyButtonText}"
                    Command="{Binding ToggleStandbyCommand}"
                    VerticalAlignment="Center"
                    MinWidth="52"
                    Padding="10,4"
                    FontSize="12" />
          </Grid>
          <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Browsing only — rotator parked, CAT paused"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       IsVisible="{Binding IsStandby}" />

            <Border Classes="live-panel">
              <StackPanel Spacing="6">
                <TextBlock Classes="live-panel-label" Text="Satellite" />
                <TextBlock Text="{Binding SelectedSatelliteName}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock FontSize="12" TextWrapping="Wrap">
                  <Run Text="Az " /><Run Text="{Binding AzimuthText}" FontWeight="SemiBold" />
                  <Run Text="  ·  El " /><Run Text="{Binding ElevationText}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock FontSize="12" TextWrapping="Wrap">
                  <Run Text="Range " /><Run Text="{Binding RangeText}" />
                  <Run Text="  ·  Alt " /><Run Text="{Binding AltitudeText}" />
                </TextBlock>
                <TextBlock Text="{Binding NextPassText}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource PassHighlightBrush}" />
              </StackPanel>
            </Border>

            <Border Classes="live-panel"
                    IsVisible="{Binding ShowRotatorStatus}">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="6">
                  <TextBlock Classes="live-panel-label" Text="Rotator" />
                  <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding RotatorAzimuthText}"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 HorizontalAlignment="Center"
                                 FontFamily="Consolas,Courier New,monospace" />
                      <TextBlock Text="Az"
                                 FontSize="10"
                                 HorizontalAlignment="Center"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding RotatorElevationText}"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 HorizontalAlignment="Center"
                                 FontFamily="Consolas,Courier New,monospace" />
                      <TextBlock Text="El"
                                 FontSize="10"
                                 HorizontalAlignment="Center"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Park"
                        Command="{Binding ParkRotatorCommand}"
                        VerticalAlignment="Top"
                        Margin="8,0,0,0"
                        MinWidth="52"
                        Padding="10,4"
                        FontSize="12" />
              </Grid>
            </Border>

            <TextBlock Text="{Binding ComPortConflictText}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       IsVisible="{Binding ShowComPortConflict}" />

            <Border Classes="live-panel"
                    IsVisible="{Binding ShowRigStatus}">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="live-panel-label"
                             Grid.Column="0"
                             Text="Radio"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding RigStatusText}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             TextAlignment="Right"
                             MaxWidth="140"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                             VerticalAlignment="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,*">
                  <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,4,0">
                    <TextBlock Text="RX"
                               FontSize="10"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="{Binding RigReceiveText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               FontFamily="Consolas,Courier New,monospace" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2" Margin="4,0,0,0">
                    <TextBlock Text="TX"
                               FontSize="10"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBlock Text="{Binding RigTransmitText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               FontFamily="Consolas,Courier New,monospace" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <Expander Grid.Row="2"
                    Header="Sky plot"
                    IsExpanded="True"
                    Margin="0,0,0,10"
                    Padding="0">
            <StackPanel Spacing="4"
                        HorizontalAlignment="Stretch"
                        MinWidth="0">
              <TextBlock FontSize="11"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         Text="Click a satellite on the map or sky plot, or use arrow keys when focused." />
              <ctrl:SkyPlotControl Height="220"
                                   TabIndex="2"
                                   MinWidth="0"
                                   HorizontalAlignment="Stretch"
                                   TrackStates="{Binding LiveStates}"
                                   FocusedNoradId="{Binding FocusedNoradId, Mode=TwoWay}"
                                   MinimumElevationDeg="{Binding MinimumElevationDeg}" />
            </StackPanel>
          </Expander>

          <DockPanel Grid.Row="3"
                     HorizontalAlignment="Stretch"
                     LastChildFill="True"
                     MinWidth="0">
            <TextBlock DockPanel.Dock="Top"
                       Text="Upcoming passes"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Margin="0,0,0,8" />
            <ListBox x:Name="PassesListBox"
                     ItemsSource="{Binding Passes}"
                     TabIndex="3"
                     Padding="0"
                     MinWidth="0"
                     HorizontalAlignment="Stretch"
                     SelectedItem="{Binding SelectedListItem, Mode=TwoWay}">
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0,0,0,2" />
                  <Setter Property="MinHeight" Value="0" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
                <Style Selector="ListBoxItem.pass-day-header:disabled">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0,6,0,2" />
                  <Setter Property="Background" Value="Transparent" />
                  <Setter Property="Opacity" Value="1" />
                </Style>
                <Style Selector="ListBoxItem.pass-day-header:disabled TextBlock">
                  <Setter Property="Opacity" Value="1" />
                  <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
                </Style>
              </ListBox.Styles>
              <ListBox.DataTemplates>
                <DataTemplate DataType="vm:PassDayHeaderViewModel">
                  <Border Padding="0,4,0,2"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,1,0,0">
                    <TextBlock Text="{Binding DateLabel}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />
                  </Border>
                </DataTemplate>
                <DataTemplate DataType="vm:PassRowViewModel">
                  <Border Padding="6,4"
                          CornerRadius="3"
                          HorizontalAlignment="Stretch"
                          Background="{Binding Highlight, Converter={x:Static theme:PassRowBackgroundConverter.Instance}}">
                    <StackPanel Spacing="2">
                      <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Right"
                                Padding="10,4"
                                CornerRadius="10"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding ShowBadge}"
                                Background="{Binding Highlight, Converter={x:Static theme:PassRowBadgeBackgroundConverter.Instance}}">
                          <TextBlock Text="{Binding BadgeText}"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     FontFamily="Consolas,Courier New,monospace"
                                     Foreground="{DynamicResource PassImminentBadgeForegroundBrush}" />
                        </Border>
                        <TextBlock Text="{Binding SatelliteName}"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   TextTrimming="CharacterEllipsis" />
                      </DockPanel>
                      <TextBlock FontSize="15"
                                 Text="{Binding TimeRangeLine}"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                      <TextBlock FontSize="15"
                                 Text="{Binding DetailsLine}"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.DataTemplates>
            </ListBox>
          </DockPanel>
        </Grid>
      </Border>
    </Grid>
  </DockPanel>
</Window>
