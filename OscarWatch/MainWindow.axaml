<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OscarWatch.ViewModels"
        xmlns:loc="using:OscarWatch.Localization"
        xmlns:ctrl="using:OscarWatch.Controls"
        xmlns:theme="using:OscarWatch.Theme"
        x:Class="OscarWatch.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{loc:Localize Key=App.Title}"
        Width="1280" Height="556"
        MinWidth="720" MinHeight="320">
  <DockPanel>
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="{loc:Localize Key=Menu.File}">
        <MenuItem Header="{loc:Localize Key=Menu.File.Close}" Command="{Binding CloseApplicationCommand}" />
      </MenuItem>
      <MenuItem Header="{loc:Localize Key=Menu.Satellites}">
        <MenuItem Header="{loc:Localize Key=Menu.Satellites.Select}" Command="{Binding OpenSatellitesCommand}" />
        <Separator />
        <MenuItem Header="{loc:Localize Key=Menu.Satellites.ManageDatabase}" Command="{Binding OpenSatelliteDatabaseCommand}" />
        <Separator />
        <MenuItem Header="{loc:Localize Key=Menu.Satellites.RefreshTles}" Command="{Binding RefreshTlesCommand}" />
        <MenuItem Header="{loc:Localize Key=Menu.Satellites.UpdateDatabase}" Command="{Binding UpdateTransponderDatabaseCommand}" />
      </MenuItem>
      <MenuItem Header="{loc:Localize Key=Menu.Passes}">
        <MenuItem Header="{loc:Localize Key=Menu.Passes.Planner}" Command="{Binding OpenPassPlanningCommand}" />
        <MenuItem Header="{loc:Localize Key=Menu.Passes.Mutual}" Command="{Binding OpenMutualPassFinderCommand}" />
        <Separator />
        <MenuItem Header="{loc:Localize Key=Menu.Passes.Sunlight}" Command="{Binding OpenSunlightPredictionCommand}" />
      </MenuItem>
      <MenuItem Header="{loc:Localize Key=Menu.Rotator}"
                Command="{Binding OpenRotatorManualCommand}"
                IsVisible="{Binding ShowRotatorMenuItem}" />
      <MenuItem Header="{loc:Localize Key=Menu.Settings}" Command="{Binding OpenSettingsCommand}" />
      <MenuItem Header="{loc:Localize Key=Menu.Help}">
        <MenuItem Header="{loc:Localize Key=Menu.Help.OperatorGuide}" Command="{Binding OpenHelpCommand}" />
        <MenuItem Header="{loc:Localize Key=Menu.Help.CheckForUpdates}" Command="{Binding CheckForUpdatesCommand}" />
        <MenuItem Header="{loc:Localize Key=Menu.Help.ReleaseNotes}" Command="{Binding OpenReleaseNotesCommand}" />
        <Separator />
        <MenuItem Header="{loc:Localize Key=Menu.Help.About}" Command="{Binding OpenAboutCommand}" />
        <MenuItem Header="{loc:Localize Key=Menu.Help.Recordings}" Command="{Binding OpenRecordingsFolderCommand}" />
        <MenuItem Header="{loc:Localize Key=Menu.Help.Logs}" Command="{Binding OpenLogsFolderCommand}" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            Padding="8,4">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding UtcClock}"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   FontFamily="Consolas,Courier New,monospace"
                   Foreground="{DynamicResource ThemeForegroundBrush}" />
        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center">
          <Button Padding="6,2"
                  MinHeight="22"
                  FontSize="11"
                  Content="{loc:Localize Key=MapTime.Back15}"
                  Command="{Binding StepMapTimeBackwardLargeCommand}"
                  ToolTip.Tip="{loc:Localize Key=MapTime.Tip.Back15}" />
          <Button Padding="6,2"
                  MinHeight="22"
                  FontSize="11"
                  Content="{loc:Localize Key=MapTime.Back5}"
                  Command="{Binding StepMapTimeBackwardCommand}"
                  ToolTip.Tip="{loc:Localize Key=MapTime.Tip.Back5}" />
          <Button Padding="6,2"
                  MinHeight="22"
                  FontSize="11"
                  Content="{loc:Localize Key=Common.Now}"
                  Command="{Binding ResetMapTimeToNowCommand}"
                  ToolTip.Tip="{loc:Localize Key=MapTime.Tip.Now}" />
          <Button Padding="6,2"
                  MinHeight="22"
                  FontSize="11"
                  Content="{loc:Localize Key=MapTime.Forward5}"
                  Command="{Binding StepMapTimeForwardCommand}"
                  ToolTip.Tip="{loc:Localize Key=MapTime.Tip.Forward5}" />
          <Button Padding="6,2"
                  MinHeight="22"
                  FontSize="11"
                  Content="{loc:Localize Key=MapTime.Forward15}"
                  Command="{Binding StepMapTimeForwardLargeCommand}"
                  ToolTip.Tip="{loc:Localize Key=MapTime.Tip.Forward15}" />
        </StackPanel>
        <TextBlock Text="{Binding StatusText}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource ThemeForegroundBrush}" />
      </DockPanel>
    </Border>

    <Grid ColumnDefinitions="*,320" ClipToBounds="False">
      <!-- Map and freq overlay are not siblings: the map repaints every second and was drawing over the overlay. -->
      <Grid x:Name="MapColumn"
            Grid.Column="0"
            ClipToBounds="True">
        <Grid x:Name="MapHost">
          <ctrl:WorldMapControl TabIndex="1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                ClipToBounds="True"
                                TrackStates="{Binding LiveStates}"
                                GroundStation="{Binding GroundStation}"
                                RemoteStation="{Binding DxStation.RemoteCoordinate}"
                                FocusedNoradId="{Binding FocusedNoradId, Mode=TwoWay}"
                                SoloFocusedSatellite="{Binding SoloFocusedSatellite}"
                                ShowFootprintMotionArrows="{Binding ShowFootprintMotionArrows}"
                                ShowGreylineOverlay="{Binding ShowGreylineOverlay}"
                                MapDisplayUtc="{Binding MapDisplayUtc}" />
        </Grid>
        <ctrl:FrequencyOverlayControl DataContext="{Binding Frequencies}"
                                      ZIndex="1"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      Margin="{Binding OverlayMargin}"
                                      IsHitTestVisible="True" />
        <ctrl:DxStationOverlayControl DataContext="{Binding DxStation}"
                                     ZIndex="1"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     Margin="{Binding OverlayMargin}"
                                     IsHitTestVisible="True" />
        <ctrl:DxStationMapLauncherControl DataContext="{Binding DxStation}"
                                          ZIndex="2"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top"
                                          Margin="0,8,8,0"
                                          IsHitTestVisible="True" />
      </Grid>

      <Border Grid.Column="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="1,0,0,0"
              Padding="8">
        <Border.Styles>
            <Style Selector="Expander">
              <Setter Property="HorizontalAlignment" Value="Stretch" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
            <Style Selector="Border.live-panel">
              <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
              <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="CornerRadius" Value="6" />
              <Setter Property="Padding" Value="10,8" />
            </Style>
            <Style Selector="TextBlock.live-panel-label">
              <Setter Property="FontSize" Value="11" />
              <Setter Property="FontWeight" Value="SemiBold" />
              <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </Style>
            <Style Selector="Button.live-sidebar-action">
              <Setter Property="MinHeight" Value="34" />
              <Setter Property="MinWidth" Value="72" />
              <Setter Property="Padding" Value="12,0" />
              <Setter Property="FontSize" Value="13" />
              <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </Border.Styles>
        <Grid x:Name="SidebarLayoutGrid"
              RowDefinitions="Auto,*,Auto"
              MinHeight="0"
              SizeChanged="OnSidebarLayoutSizeChanged">
          <ScrollViewer x:Name="SidebarTopScrollViewer"
                        Grid.Row="0"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel MinWidth="0">
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0"
                       Text="{loc:Localize Key=Main.Live}"
                       FontWeight="SemiBold"
                       FontSize="14"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Classes="live-sidebar-action"
                    Content="{Binding StandbyButtonText}"
                    Command="{Binding ToggleStandbyCommand}"
                    VerticalAlignment="Center" />
          </Grid>
          <StackPanel Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="{loc:Localize Key=Main.Standby.Hint}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       IsVisible="{Binding IsStandby}" />

            <Border Classes="live-panel">
              <StackPanel Spacing="6">
                <TextBlock Classes="live-panel-label" Text="{loc:Localize Key=Main.Satellite}" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0"
                             Text="{Binding SelectedSatelliteName}"
                             FontWeight="SemiBold"
                             FontSize="14"
                             TextTrimming="CharacterEllipsis" />
                  <StackPanel Grid.Column="1"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              IsVisible="{Binding ShowSunlightStatus}">
                    <TextBlock Text="{loc:Localize Key=Main.Sunlight}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               IsVisible="{Binding IsSatelliteSunlit}"
                               Foreground="{DynamicResource SunlightStatusBrush}"
                               AutomationProperties.Name="{loc:Localize Key=A11y.SatelliteSunlight}" />
                    <TextBlock Text="{loc:Localize Key=Main.Eclipse}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               IsVisible="{Binding IsSatelliteInEclipse}"
                               Foreground="{DynamicResource EclipseStatusBrush}"
                               AutomationProperties.Name="{loc:Localize Key=A11y.SatelliteEclipse}" />
                  </StackPanel>
                </Grid>
                <TextBlock FontSize="12" TextWrapping="Wrap">
                  <Run Text="{loc:Localize Key=Main.Az}" /><Run Text="{Binding AzimuthText}" FontWeight="SemiBold" />
                  <Run Text="{loc:Localize Key=Main.El}" /><Run Text="{Binding ElevationText}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock FontSize="12" TextWrapping="Wrap">
                  <Run Text="{loc:Localize Key=Main.Range}" /><Run Text="{Binding RangeText}" />
                  <Run Text="{loc:Localize Key=Main.Alt}" /><Run Text="{Binding AltitudeText}" />
                </TextBlock>
                <TextBlock Text="{Binding NextPassText}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource PassHighlightBrush}" />
              </StackPanel>
            </Border>

            <Border Classes="live-panel"
                    IsVisible="{Binding ShowRotatorStatus}">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="6">
                  <TextBlock Classes="live-panel-label" Text="{loc:Localize Key=Main.Rotator}" />
                  <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding RotatorAzimuthText}"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 HorizontalAlignment="Center"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 FontFamily="Consolas,Courier New,monospace" />
                      <TextBlock Text="{loc:Localize Key=Main.Rotator.Az}"
                                 FontSize="10"
                                 HorizontalAlignment="Center"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                      <TextBlock Text="{Binding RotatorElevationText}"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 HorizontalAlignment="Center"
                                 FontFamily="Consolas,Courier New,monospace" />
                      <TextBlock Text="{loc:Localize Key=Main.Rotator.El}"
                                 FontSize="10"
                                 HorizontalAlignment="Center"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="live-sidebar-action"
                        Content="{Binding RotatorParkButtonText}"
                        Command="{Binding ParkRotatorCommand}"
                        VerticalAlignment="Top"
                        Margin="8,0,0,0" />
              </Grid>
            </Border>

            <TextBlock Text="{Binding ComPortConflictText}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       IsVisible="{Binding ShowComPortConflict}" />

            <Border Classes="live-panel"
                    IsVisible="{Binding ShowRigStatus}">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                  <TextBlock Classes="live-panel-label"
                             Grid.Column="0"
                             Text="{loc:Localize Key=Main.Radio}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding RigStatusText}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             TextAlignment="Right"
                             MaxWidth="140"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0" />
                  <Button Grid.Column="2"
                          Classes="live-sidebar-action"
                          Content="{Binding RigCatPauseButtonText}"
                          Command="{Binding ToggleRigCatPauseCommand}"
                          FontSize="11"
                          MinWidth="0"
                          Padding="8,0"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          ToolTip.Tip="{loc:Localize Key=Main.Radio.CatPauseTip}" />
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <TextBlock Grid.Column="0"
                             FontSize="12"
                             TextWrapping="Wrap">
                    <Run Text="{loc:Localize Key=Main.Radio.Rx}"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <Run Text="{Binding RigReceiveText}"
                         FontWeight="SemiBold"
                         FontFamily="Consolas,Courier New,monospace" />
                  </TextBlock>
                  <TextBlock Grid.Column="1"
                             FontSize="12"
                             TextWrapping="Wrap">
                    <Run Text="{loc:Localize Key=Main.Radio.Tx}"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <Run Text="{Binding RigTransmitText}"
                         FontWeight="SemiBold"
                         FontFamily="Consolas,Courier New,monospace" />
                  </TextBlock>
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>

          <Expander Header="{loc:Localize Key=Main.SkyPlot}"
                    IsExpanded="{Binding IsSkyPlotExpanded, Mode=TwoWay}"
                    Margin="0,0,0,10"
                    Padding="0">
            <StackPanel Spacing="4"
                        HorizontalAlignment="Stretch"
                        MinWidth="0">
              <TextBlock FontSize="11"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         Text="{loc:Localize Key=Main.SkyPlot.Hint}" />
              <ctrl:SkyPlotControl Height="220"
                                   TabIndex="2"
                                   MinWidth="0"
                                   HorizontalAlignment="Stretch"
                                   TrackStates="{Binding LiveStates}"
                                   FocusedNoradId="{Binding FocusedNoradId, Mode=TwoWay}"
                                   SoloFocusedSatellite="{Binding SoloFocusedSatellite}"
                                   MinimumElevationDeg="{Binding MinimumElevationDeg}" />
            </StackPanel>
          </Expander>
            </StackPanel>
          </ScrollViewer>

          <Expander Grid.Row="1"
                    Header="{loc:Localize Key=Main.Passes}"
                    IsExpanded="{Binding IsPassesExpanded, Mode=TwoWay}"
                    Margin="0,8,0,0"
                    Padding="0"
                    MinHeight="0"
                    VerticalAlignment="Stretch">
            <ListBox x:Name="PassesListBox"
                     ItemsSource="{Binding Passes}"
                     TabIndex="3"
                     Padding="0"
                     MinWidth="0"
                     MinHeight="0"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     SelectedItem="{Binding SelectedListItem, Mode=TwoWay}">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0,0,0,2" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
                <Style Selector="ListBoxItem:not(.pass-day-header)">
                  <Setter Property="MinHeight" Value="68" />
                </Style>
                <Style Selector="ListBoxItem.pass-day-header:disabled">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0,6,0,2" />
                  <Setter Property="Background" Value="Transparent" />
                  <Setter Property="Opacity" Value="1" />
                </Style>
                <Style Selector="ListBoxItem.pass-day-header:disabled TextBlock">
                  <Setter Property="Opacity" Value="1" />
                  <Setter Property="Foreground" Value="{DynamicResource ThemeForegroundBrush}" />
                </Style>
              </ListBox.Styles>
              <ListBox.DataTemplates>
                <DataTemplate DataType="vm:PassDayHeaderViewModel">
                  <Border Padding="0,4,0,2"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,1,0,0">
                    <TextBlock Text="{Binding DateLabel}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource ThemeForegroundBrush}" />
                  </Border>
                </DataTemplate>
                <DataTemplate DataType="vm:PassRowViewModel">
                  <Border Padding="6,4"
                          CornerRadius="3"
                          HorizontalAlignment="Stretch"
                          Background="{Binding Highlight, Converter={x:Static theme:PassRowBackgroundConverter.Instance}}">
                    <StackPanel Spacing="2">
                      <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Right"
                                Padding="10,4"
                                CornerRadius="10"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding ShowBadge}"
                                Background="{Binding Highlight, Converter={x:Static theme:PassRowBadgeBackgroundConverter.Instance}}">
                          <TextBlock Text="{Binding BadgeText}"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     FontFamily="Consolas,Courier New,monospace"
                                     Foreground="{Binding Highlight, Converter={x:Static theme:PassRowBadgeForegroundConverter.Instance}}" />
                        </Border>
                        <TextBlock Text="{Binding SatelliteName}"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   TextTrimming="CharacterEllipsis" />
                      </DockPanel>
                      <TextBlock FontSize="15"
                                 Text="{Binding TimeRangeLine}"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                      <TextBlock FontSize="15"
                                 Text="{Binding DetailsLine}"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.DataTemplates>
            </ListBox>
          </Expander>

          <Expander Grid.Row="2"
                    Header="{loc:Localize Key=Main.HamsAtRoves}"
                    IsExpanded="{Binding IsHamsAtRovesExpanded, Mode=TwoWay}"
                    IsVisible="{Binding ShowHamsAtRovesPanel}"
                    Margin="0,8,0,0"
                    Padding="0">
            <StackPanel Spacing="4" MinWidth="0">
              <Border x:Name="HamsAtRovesResizeGrip"
                      Height="10"
                      Margin="0,0,0,2"
                      Background="Transparent"
                      Cursor="SizeNorthSouth"
                      PointerPressed="OnHamsAtRovesResizePointerPressed"
                      HorizontalAlignment="Stretch"
                      ToolTip.Tip="{loc:Localize Key=Main.HamsAtRoves.ResizeGrip}">
                <Border Height="4"
                        Width="36"
                        CornerRadius="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />
              </Border>
              <TextBlock Text="{Binding HamsAtRovesStatusText}"
                         FontSize="15"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         IsVisible="{Binding ShowHamsAtRovesStatus}" />
              <ListBox x:Name="HamsAtRovesListBox"
                       ItemsSource="{Binding HamsAtRoves}"
                       Tapped="OnHamsAtRovesListTapped"
                       Padding="0"
                       MinWidth="0"
                       Height="{Binding HamsAtRovesPanelHeight}"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,2" />
                    <Setter Property="MinHeight" Value="72" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Cursor" Value="Hand" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="vm:HamsAtRoveRowViewModel">
                    <Border Padding="10,8"
                            CornerRadius="3"
                            HorizontalAlignment="Stretch"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="3">
                          <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        Spacing="4"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center">
                              <Border Padding="10,4"
                                      CornerRadius="10"
                                      Background="{DynamicResource PassRecordingBadgeBackgroundBrush}"
                                      IsVisible="{Binding ShowNeededGrids}">
                                <TextBlock Text="{Binding NeededGridsText}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas,Courier New,monospace"
                                           Foreground="{DynamicResource PassRecordingBadgeForegroundBrush}" />
                              </Border>
                              <Border Padding="10,4"
                                      CornerRadius="10"
                                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                      BorderThickness="1"
                                      IsVisible="{Binding ShowWorkedGrids}">
                                <TextBlock Text="{Binding WorkedGridsText}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas,Courier New,monospace"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                              </Border>
                              <Border Padding="10,4"
                                      CornerRadius="10"
                                      Background="{DynamicResource HamsAtGridBadgeBackgroundBrush}"
                                      IsVisible="{Binding ShowGrids}">
                                <TextBlock Text="{Binding GridsText}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas,Courier New,monospace"
                                           Foreground="{DynamicResource PassInProgressBadgeForegroundBrush}" />
                              </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Callsign}"
                                       FontWeight="SemiBold"
                                       FontSize="16"
                                       TextTrimming="CharacterEllipsis" />
                          </DockPanel>
                          <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right"
                                    Padding="10,4"
                                    CornerRadius="10"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="1"
                                    IsVisible="{Binding ShowSatellite}">
                              <TextBlock Text="{Binding SatelliteName}"
                                         FontSize="14"
                                         FontWeight="SemiBold"
                                         FontFamily="Consolas,Courier New,monospace" />
                            </Border>
                            <TextBlock Text="{Binding TimeWindowText}"
                                       FontSize="15"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                          </DockPanel>
                          <TextBlock Text="{Binding Comment}"
                                     FontSize="15"
                                     TextTrimming="CharacterEllipsis"
                                     IsVisible="{Binding ShowComment}"
                                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </Expander>
        </Grid>
      </Border>
    </Grid>
  </DockPanel>
</Window>
